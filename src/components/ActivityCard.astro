---
import activity from '../data/public-activity.json';

const archiveTotal = activity.totals.worklog + activity.totals.newsletter + activity.totals.insights;
const recent = activity.recent.slice(0, 4);
const metrics = [
  { label: '최근 7일', value: activity.totals.last_7_days, detail: '공개 기록' },
  { label: '최근 30일', value: activity.totals.last_30_days, detail: '공개 기록' },
  { label: '전체 아카이브', value: archiveTotal, detail: '제목·날짜 기준' },
];
---
<section class="activity-section" aria-labelledby="activity-title">
  <div class="activity-head">
    <div>
      <p class="activity-kicker">PUBLIC ACTIVITY</p>
      <h2 id="activity-title">최근 공개 활동</h2>
    </div>
    <p>
      작업일지·뉴스레터·인사이트에 실제로 공개된 기록만 모았습니다.
      실시간 세션이나 기기 상태를 보여주는 화면이 아닙니다.
    </p>
  </div>

  <div class="activity-body">
    <dl class="activity-metrics" aria-label="공개 활동 집계">
      {metrics.map((metric) => (
        <div>
          <dt>{metric.label}</dt>
          <dd>{metric.value}</dd>
          <span>{metric.detail}</span>
        </div>
      ))}
    </dl>

    <div class="activity-recent">
      <div class="activity-recent-head">
        <h3>최근 기록</h3>
        <span>{activity.as_of} 기준</span>
      </div>
      <ul>
        {recent.map((item) => (
          <li>
            <a href={item.href}>
              <span class="activity-meta">{item.label} · {item.date}</span>
              <strong>{item.title}</strong>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <p class="activity-privacy">
    공개 범위: 집계와 허용된 공개 제목만 · 원문 로그, 입력 내용, 내부 경로, 기기 정보는 수집하지 않습니다.
  </p>
</section>

<style>
  .activity-section {
    padding: 34px 0 0;
    border-top: 1px solid var(--border);
  }

  .activity-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 420px);
    gap: 32px;
    align-items: end;
    margin-bottom: 24px;
  }

  .activity-kicker {
    margin-bottom: 12px;
    color: var(--fg-mute);
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
  }

  .activity-head h2 {
    font-size: 34px;
    line-height: 1.2;
  }

  .activity-head > p {
    color: var(--fg-dim);
    font-size: 15px;
    line-height: 1.65;
    word-break: keep-all;
  }

  .activity-body {
    display: grid;
    grid-template-columns: minmax(260px, 0.8fr) minmax(0, 1.2fr);
    gap: 48px;
  }

  .activity-metrics {
    border-top: 1px solid var(--border);
  }

  .activity-metrics div {
    display: grid;
    grid-template-columns: 108px minmax(0, 1fr) auto;
    gap: 16px;
    align-items: baseline;
    min-height: 72px;
    padding: 18px 0;
    border-bottom: 1px solid var(--border);
  }

  .activity-metrics dt,
  .activity-metrics span,
  .activity-recent-head span,
  .activity-meta {
    color: var(--fg-mute);
    font-size: 12px;
  }

  .activity-metrics dt,
  .activity-metrics dd,
  .activity-recent-head span {
    font-family: var(--mono);
  }

  .activity-metrics dd {
    color: var(--fg);
    font-size: 24px;
    font-weight: 700;
  }

  .activity-metrics span {
    white-space: nowrap;
  }

  .activity-recent {
    min-width: 0;
    border-top: 1px solid var(--border);
  }

  .activity-recent-head {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: baseline;
    min-height: 58px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }

  .activity-recent-head h3 {
    font-size: 18px;
  }

  .activity-recent ul {
    list-style: none;
  }

  .activity-recent li {
    border-bottom: 1px solid var(--border);
  }

  .activity-recent a {
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr);
    gap: 18px;
    align-items: baseline;
    min-height: 66px;
    padding: 17px 0;
    color: var(--fg);
    text-decoration: none;
  }

  .activity-recent a:hover {
    background: var(--bg-elev);
    color: var(--fg);
  }

  .activity-recent strong {
    min-width: 0;
    font-size: 15px;
    line-height: 1.5;
  }

  .activity-privacy {
    margin-top: 18px;
    color: var(--fg-mute);
    font-size: 12px;
    line-height: 1.6;
  }

  @media (max-width: 820px) {
    .activity-head,
    .activity-body {
      grid-template-columns: 1fr;
    }

    .activity-body {
      gap: 34px;
    }
  }

  @media (max-width: 560px) {
    .activity-head h2 {
      font-size: 28px;
    }

    .activity-metrics div,
    .activity-recent a {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .activity-metrics span {
      white-space: normal;
    }
  }
</style>

---
import { company } from '../data/site';
---
<footer>
  <div class="foot-head">
    <strong>{company.name}</strong>
    <a href={`mailto:${company.email}`}>{company.email}</a>
  </div>
  <div class="biz">
    <span>{company.name} · 대표 {company.representative}</span>
    <span>사업자등록번호 {company.bizNumber}</span>
    <span>통신판매업신고번호 {company.mailOrderNumber}</span>
    <span>{company.address}</span>
    <span>{company.category}</span>
  </div>
  <div class="copy">© 2026 {company.name}. All rights reserved.</div>
  <style>
    footer {
      width: min(calc(100% - 48px), 1120px);
      margin: 0 auto;
      padding: 34px 0 56px;
      border-top: 1px solid var(--border);
      color: var(--fg-mute);
      font-size: 12px;
    }
    .foot-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
    }
    .foot-head strong { color: var(--fg); font-size: 14px; }
    .foot-head a { color: var(--fg); text-decoration: none; }
    .foot-head a:hover { text-decoration: underline; }
    .biz { display: flex; flex-wrap: wrap; gap: 6px 14px; }
    .copy { margin-top: 16px; color: var(--fg-mute); }
    @media (max-width: 640px) {
      footer { width: min(calc(100% - 32px), 1120px); padding-bottom: 42px; }
      .foot-head { display: block; }
      .foot-head a { display: inline-block; margin-top: 6px; }
      .biz { flex-direction: column; gap: 4px; }
    }
  </style>
</footer>

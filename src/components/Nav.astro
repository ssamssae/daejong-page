---
const primary = [
  { href: 'https://kangdaejong.com', label: '회사소개' },
  { href: 'https://ceo.kangdaejong.com', label: '대표소개', cls: 'home-link' },
  { href: '/', label: '작업일지' },
  { href: '/newsletter', label: '뉴스레터' },
  { href: '/apps', label: 'products' },
];
const secondary = [
  { href: '/worklog', label: 'worklog' },
  { href: '/insights', label: 'insights' },
  { href: '/system', label: 'system' },
  { href: '/lab', label: 'lab' },
];
---
<nav>
  <div class="nav-inner">
    <a class="brand" href="/"><img src="/minusbeta-badge.svg" alt="마이너스베타스튜디오" width="30" height="30" /></a>
    <div class="nav-links">
      {primary.map(l => <a href={l.href} class={l.cls}>{l.label}</a>)}
    </div>
  </div>
  <div class="nav-sub">
    {secondary.map(l => <a href={l.href}>{l.label}</a>)}
  </div>
  <style>
    nav { border-bottom: 1px solid var(--border); background: var(--bg); position: sticky; top: 0; z-index: 10; }
    .nav-inner { max-width: 760px; margin: 0 auto; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .brand { display: inline-flex; align-items: center; }
    .brand img { height: 30px; width: 30px; display: block; }
    .nav-links { display: flex; gap: 18px; flex-wrap: wrap; font-family: var(--mono); font-size: 13px; }
    .nav-links a { color: var(--fg-dim); }
    .nav-links a:hover { color: var(--magenta); }
    .nav-links a.home-link { color: var(--cyan); }
    .nav-links a.home-link:hover { color: var(--magenta); }
    .nav-sub { max-width: 760px; margin: 0 auto; padding: 0 24px 12px; display: flex; gap: 14px; flex-wrap: wrap; font-family: var(--mono); font-size: 12px; }
    .nav-sub a { color: var(--fg-dim); opacity: 0.7; }
    .nav-sub a:hover { color: var(--magenta); opacity: 1; }
  </style>
</nav>

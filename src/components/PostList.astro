---
// 작업일지/뉴스레터/인사이트 공통 목록 렌더. base 는 컬렉션 라우트 prefix.
interface Post {
  id: string;
  data: { title: string; date: string; version?: string };
}
const { posts, base } = Astro.props as { posts: Post[]; base: string };
---
<ul class="post-list">
  {posts.map((p) => {
    // 뉴스레터는 version 이 "ep6" 형태 — "Ep.6" 배지로 노출. worklog(v1.0.1)·insights(없음)는 미표시.
    const epMatch = p.data.version?.match(/^ep(\d+)$/i);
    return (
      <li>
        <a href={`${base}/${p.id}/`}>
          <span class="date">{p.data.date}</span>
          <span class="ep" aria-hidden={epMatch ? undefined : 'true'}>{epMatch ? `Ep.${epMatch[1]}` : ''}</span>
          <span class="title">{p.data.title}</span>
        </a>
      </li>
    );
  })}
</ul>
<style>
  .post-list { list-style: none; display: flex; flex-direction: column; gap: 0; }
  .post-list li { border-bottom: 1px solid var(--border); }
  .post-list a {
    display: grid;
    grid-template-columns: 96px 56px minmax(0, 1fr);
    gap: 12px;
    align-items: baseline;
    min-height: 58px;
    padding: 16px 0;
    color: var(--fg);
    text-decoration: none;
  }
  .post-list a:hover { color: var(--fg); background: var(--bg-elev); }
  .date { font-size: 12px; color: var(--fg-mute); }
  .ep { font-size: 12px; color: var(--fg-mute); }
  .title { min-width: 0; font-size: 15px; font-weight: 600; }
  @media (max-width: 520px) {
    .post-list a {
      grid-template-columns: 1fr;
      gap: 4px;
      min-height: auto;
      padding: 14px 0;
    }
  }
</style>

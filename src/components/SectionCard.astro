---
// 허브 홈 5섹션 그리드 카드.
const { href, title, desc, accent } = Astro.props as {
  href: string; title: string; desc: string; accent?: 'cyan' | 'magenta';
};
const accentVar = accent === 'magenta' ? 'var(--magenta)' : 'var(--cyan)';
---
<a class="section-card" href={href}>
  <span class="sc-title" style={`color:${accentVar}`}>{title}</span>
  <span class="sc-desc">{desc}</span>
  <span class="sc-arrow" style={`color:${accentVar}`}>→</span>
</a>
<style>
  .section-card {
    display: flex; flex-direction: column; gap: 8px; position: relative;
    border: 1px solid var(--border); border-radius: 10px; padding: 20px;
    background: var(--bg-elev); color: var(--fg); transition: border-color .15s;
  }
  .section-card:hover { border-color: var(--cyan); color: var(--fg); }
  .sc-title { font-family: var(--mono); font-weight: 600; font-size: 16px; }
  .sc-desc { font-size: 13px; color: var(--fg-dim); line-height: 1.55; }
  .sc-arrow { position: absolute; top: 18px; right: 18px; font-family: var(--mono); }
</style>

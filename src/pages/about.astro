---
import Layout from '../layouts/Layout.astro';

const facts = [
  { label: 'ROLE', value: '마이너스베타스튜디오 대표' },
  { label: 'WORK', value: '모바일 앱 · 웹 · 오픈소스 자동화' },
  { label: 'BASE', value: '대한민국 · 1인 제작과 운영' },
];

const principles = [
  {
    number: '01',
    title: '작게 만들고 실제로 공개합니다.',
    body: '완벽한 계획보다 직접 써볼 수 있는 작은 제품을 먼저 만듭니다. 공개한 뒤에야 보이는 문제를 다음 작업의 출발점으로 삼습니다.',
  },
  {
    number: '02',
    title: '운영에서 반복되는 일은 줄입니다.',
    body: '앱을 만드는 일과 운영하는 일을 따로 보지 않습니다. 반복되는 확인과 전달은 자동화하고, 사람이 판단해야 하는 일에 시간을 씁니다.',
  },
  {
    number: '03',
    title: '결과와 과정을 함께 남깁니다.',
    body: '작업일지, 커밋, 뉴스레터로 선택과 실패를 기록합니다. 기록은 보여주기 위한 장식보다 다음 결정을 빠르게 만드는 작업 도구에 가깝습니다.',
  },
];

const workshopRoutes = [
  {
    label: 'PRODUCTS',
    title: '만든 것',
    body: '모바일 앱, 웹 서비스, 공개 자동화 도구를 한곳에서 봅니다.',
    href: '/products/',
  },
  {
    label: 'WORKLOG',
    title: '일한 기록',
    body: '무엇을 만들고 고쳤는지 하루 단위의 빌드 로그로 남깁니다.',
    href: '/worklog/',
  },
  {
    label: 'SYSTEM',
    title: '굴리는 방식',
    body: '여러 기기와 AI 에이전트를 묶어 1인 작업장을 운영하는 구조입니다.',
    href: '/system/',
  },
];
---
<Layout
  title="강대종 소개 — 마이너스베타스튜디오"
  description="마이너스베타스튜디오 대표 강대종의 소개와 제품 제작, 기록, 자동화 작업 방식."
>
  <div class="about-page">
    <section class="about-hero" aria-labelledby="about-title">
      <div class="hero-copy">
        <p class="eyebrow">FOUNDER · BUILDER · OPERATOR</p>
        <h1 id="about-title">혼자 만들지만,<br />시스템으로 운영합니다.</h1>
        <p class="lead">
          강대종입니다. 비개발자로 시작해 작은 앱과 웹 서비스를 직접 만들고,
          AI와 자동화를 붙여 오래 운영할 수 있는 1인 작업장을 만들고 있습니다.
        </p>
        <div class="hero-actions" aria-label="주요 이동">
          <a class="button primary" href="/products/">제품 보기</a>
          <a class="button secondary" href="/worklog/">작업 기록 보기</a>
        </div>
      </div>

      <figure class="portrait">
        <img
          src="/daejong-profile-suit.jpg"
          width="960"
          height="1280"
          alt="정장을 입은 강대종 프로필 사진"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <figcaption>
          <span>강대종</span>
          <span>MINUS BETA STUDIO</span>
        </figcaption>
      </figure>
    </section>

    <section class="profile-section" aria-labelledby="profile-title">
      <div class="section-label">
        <span>01</span>
        <span>ABOUT</span>
      </div>
      <div class="profile-copy">
        <h2 id="profile-title">제품을 만들고,<br />운영 방식을 함께 다듬습니다.</h2>
        <p>
          마이너스베타스튜디오 이름으로 생활에 가까운 모바일 앱과 짧게 쓰는 웹 서비스,
          AI 작업 도구를 만듭니다. 아이디어를 제품으로 옮기는 일부터 출시 뒤의 수정과
          기록까지 한 흐름으로 다룹니다.
        </p>
        <p>
          코딩을 전공하지 않았기 때문에 어려운 기술을 늘어놓기보다 실제로 작동하는지,
          혼자서도 계속 관리할 수 있는지를 먼저 봅니다. 빠르게 만들되 검증 가능한 흔적을
          남기는 것이 제 작업 방식의 중심입니다.
        </p>
      </div>
      <dl class="facts" aria-label="강대종 프로필 요약">
        {facts.map((fact) => (
          <div>
            <dt>{fact.label}</dt>
            <dd>{fact.value}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="principles-section" aria-labelledby="principles-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">WORKING PRINCIPLES</p>
          <h2 id="principles-title">일하는 세 가지 원칙</h2>
        </div>
        <p>혼자 일할수록 작은 단위, 자동화, 기록이 필요하다고 믿습니다.</p>
      </div>

      <ol class="principle-list">
        {principles.map((principle) => (
          <li>
            <span>{principle.number}</span>
            <strong>{principle.title}</strong>
            <p>{principle.body}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="workshop-section" aria-labelledby="workshop-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">PUBLIC WORKSHOP</p>
          <h2 id="workshop-title">말보다 작업장을 보여드립니다.</h2>
        </div>
        <p>공개 가능한 제품, 과정, 시스템을 실제 페이지에서 확인할 수 있습니다.</p>
      </div>

      <div class="route-grid">
        {workshopRoutes.map((route, index) => (
          <a class="route-card" href={route.href}>
            <span class="route-top">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <span>{route.label}</span>
            </span>
            <strong>{route.title}</strong>
            <span class="route-body">{route.body}</span>
            <span class="route-link">둘러보기 →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="story-section" aria-labelledby="story-title">
      <div class="section-label">
        <span>02</span>
        <span>NOW</span>
      </div>
      <div class="story-copy">
        <h2 id="story-title">지금은 AI와 함께 일하는<br />1인 제작 방식을 실험합니다.</h2>
        <p>
          폰, 데스크탑, 맥에서 이어지는 작업 흐름에 AI 에이전트를 연결하고 있습니다.
          목표는 사람을 흉내 내는 거대한 자동화가 아니라, 반복 업무를 덜어내고 판단과 제작에
          더 오래 집중할 수 있는 현실적인 작업장을 만드는 것입니다.
        </p>
      </div>
      <aside class="now-note" aria-label="현재 관심사">
        <p class="eyebrow">CURRENT FOCUS</p>
        <strong>1인 회사의 제작·운영 자동화</strong>
        <span>앱 제작 · AI 브릿지 · 작업 기록 · 실전 가이드</span>
      </aside>
    </section>

    <section class="contact-section" aria-labelledby="contact-title">
      <div>
        <p class="eyebrow">CONTACT</p>
        <h2 id="contact-title">작은 제품과 운영 이야기를 나눕니다.</h2>
        <p>협업, 제품, 자동화에 관한 이야기는 메일로 보내주세요.</p>
      </div>
      <div class="contact-actions">
        <a class="button primary" href="mailto:ssamssae@naver.com">메일 보내기</a>
        <a class="text-link" href="/newsletter/">뉴스레터 읽기 →</a>
      </div>
    </section>
  </div>

  <style>
    .about-page {
      display: flex;
      flex-direction: column;
      gap: 88px;
    }

    .about-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 390px);
      gap: 56px;
      align-items: end;
      padding: 18px 0 48px;
      border-bottom: 1px solid var(--border);
    }

    .eyebrow {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      line-height: 1.4;
      margin-bottom: 12px;
    }

    .hero-copy h1 {
      max-width: 780px;
      font-size: clamp(50px, 7vw, 82px);
      line-height: 1.02;
      word-break: keep-all;
    }

    .lead {
      max-width: 700px;
      margin-top: 26px;
      color: var(--fg-dim);
      font-size: 20px;
      line-height: 1.72;
      word-break: keep-all;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 34px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 18px;
      border: 1px solid var(--fg);
      border-radius: 8px;
      color: var(--fg);
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
    }

    .button:hover {
      color: var(--fg);
      text-decoration: none;
    }

    .button.primary {
      border-color: var(--accent-cta);
      background: var(--accent-cta);
      color: #fff;
    }

    .button.primary:hover {
      border-color: var(--accent-dim);
      background: var(--accent-dim);
      color: #fff;
    }

    .button.secondary {
      background: var(--bg);
    }

    .button.secondary:hover {
      background: var(--bg-elev);
    }

    .portrait {
      position: relative;
      overflow: hidden;
      aspect-ratio: 3 / 4;
      margin: 0;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg-elev);
    }

    .portrait img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }

    .portrait figcaption {
      position: absolute;
      right: 12px;
      bottom: 12px;
      left: 12px;
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 12px;
      border: 1px solid rgba(255, 255, 255, .7);
      border-radius: 7px;
      background: rgba(255, 255, 255, .88);
      backdrop-filter: blur(12px);
      color: var(--fg);
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 600;
    }

    .profile-section,
    .story-section {
      display: grid;
      grid-template-columns: 120px minmax(0, 1fr) minmax(260px, 340px);
      gap: 40px;
      align-items: start;
    }

    .section-label {
      display: flex;
      flex-direction: column;
      gap: 4px;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .profile-copy h2,
    .story-copy h2 {
      max-width: 650px;
      font-size: 38px;
      line-height: 1.18;
      word-break: keep-all;
    }

    .profile-copy p,
    .story-copy p {
      max-width: 680px;
      margin-top: 20px;
      color: var(--fg-dim);
      font-size: 16px;
      line-height: 1.82;
      word-break: keep-all;
    }

    .facts {
      border-top: 1px solid var(--fg);
    }

    .facts div {
      padding: 16px 0 18px;
      border-bottom: 1px solid var(--border);
    }

    .facts dt {
      margin-bottom: 7px;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 600;
    }

    .facts dd {
      color: var(--fg);
      font-size: 14px;
      font-weight: 700;
      line-height: 1.55;
      word-break: keep-all;
    }

    .section-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 360px);
      gap: 32px;
      align-items: end;
      margin-bottom: 24px;
    }

    .section-head h2 {
      max-width: 720px;
      font-size: 36px;
      line-height: 1.2;
      word-break: keep-all;
    }

    .section-head > p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.65;
      word-break: keep-all;
    }

    .principle-list {
      border-top: 1px solid var(--border);
      list-style: none;
    }

    .principle-list li {
      display: grid;
      grid-template-columns: 80px minmax(240px, 330px) minmax(0, 1fr);
      gap: 28px;
      align-items: baseline;
      padding: 26px 0;
      border-bottom: 1px solid var(--border);
    }

    .principle-list span {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .principle-list strong {
      color: var(--fg);
      font-size: 21px;
      line-height: 1.35;
      word-break: keep-all;
    }

    .principle-list p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.7;
      word-break: keep-all;
    }

    .route-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
    }

    .route-card {
      display: flex;
      min-height: 260px;
      flex-direction: column;
      padding: 24px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      color: var(--fg);
      text-decoration: none;
    }

    .route-card:hover {
      background: var(--bg-elev);
      color: var(--fg);
      text-decoration: none;
    }

    .route-top {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .route-card strong {
      margin-top: 40px;
      font-size: 25px;
      line-height: 1.25;
    }

    .route-body {
      margin-top: 14px;
      color: var(--fg-dim);
      font-size: 14px;
      line-height: 1.65;
      word-break: keep-all;
    }

    .route-link {
      margin-top: auto;
      padding-top: 30px;
      font-size: 13px;
      font-weight: 700;
    }

    .now-note {
      padding: 22px;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg-elev);
    }

    .now-note strong,
    .now-note span {
      display: block;
    }

    .now-note strong {
      color: var(--fg);
      font-size: 20px;
      line-height: 1.35;
      word-break: keep-all;
    }

    .now-note span {
      margin-top: 18px;
      color: var(--fg-dim);
      font-size: 13px;
      line-height: 1.65;
    }

    .contact-section {
      display: flex;
      justify-content: space-between;
      gap: 40px;
      align-items: end;
      padding: 36px;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--fg);
      color: var(--bg);
    }

    .contact-section .eyebrow,
    .contact-section p {
      color: rgba(255, 255, 255, .68);
    }

    .contact-section h2 {
      max-width: 640px;
      font-size: 34px;
      line-height: 1.2;
      word-break: keep-all;
    }

    .contact-section p:not(.eyebrow) {
      margin-top: 12px;
      font-size: 15px;
    }

    .contact-actions {
      display: flex;
      flex: 0 0 auto;
      flex-wrap: wrap;
      gap: 18px;
      align-items: center;
    }

    .contact-section .button.primary {
      border-color: #fff;
      background: #fff;
      color: var(--fg);
    }

    .contact-section .button.primary:hover {
      background: var(--bg-elev2);
      color: var(--fg);
    }

    .text-link {
      color: rgba(255, 255, 255, .82);
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
    }

    .text-link:hover {
      color: #fff;
      text-decoration: underline;
    }

    @media (max-width: 920px) {
      .about-page {
        gap: 72px;
      }

      .about-hero,
      .profile-section,
      .story-section,
      .section-head {
        grid-template-columns: 1fr;
      }

      .portrait {
        width: min(100%, 420px);
      }

      .section-label {
        flex-direction: row;
        gap: 12px;
      }

      .facts {
        margin-top: 8px;
      }

      .route-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .about-page {
        gap: 58px;
      }

      .about-hero {
        gap: 34px;
        padding-top: 10px;
      }

      .hero-copy h1 {
        font-size: 40px;
      }

      .lead {
        font-size: 17px;
      }

      .hero-actions,
      .contact-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .button {
        width: 100%;
      }

      .profile-copy h2,
      .story-copy h2,
      .section-head h2,
      .contact-section h2 {
        font-size: 29px;
      }

      .principle-list li,
      .route-grid {
        grid-template-columns: 1fr;
      }

      .principle-list li {
        gap: 10px;
      }

      .principle-list p {
        margin-top: 4px;
      }

      .route-card {
        min-height: 220px;
      }

      .contact-section {
        display: grid;
        padding: 24px;
      }
    }
  </style>
</Layout>

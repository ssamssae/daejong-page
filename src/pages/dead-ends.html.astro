---
import Layout from '../layouts/Layout.astro';
import '../styles/lab.css';
---
<Layout title="막다른 길 - 강대종" description="시도했지만 막힌 작업을 모아둔 실패 사례 기록. 코레일 Playwright 봇 탐지처럼 브라우저 자동화 차단, API 제한, 구조적 한계를 증상과 판단 근거, 포기 이유, 재시도 조건까지 남겨 다음 시도에서 같은 길을 피합니다.">
  <Fragment slot="head">
  <link rel="canonical" href="https://work.kangdaejong.com/dead-ends.html">
  <script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://work.kangdaejong.com/#person",
      "name": "강대종",
      "jobTitle": "Solo founder / Vibe coder",
      "url": "https://work.kangdaejong.com/",
      "sameAs": ["https://github.com/ssamssae"],
      "description": "1인 개발자 / Vibe coder / Solo founder"
    },
    {
      "@type": "WebSite",
      "@id": "https://work.kangdaejong.com/#website",
      "name": "강대종",
      "url": "https://work.kangdaejong.com/",
      "inLanguage": "ko",
      "author": {"@id": "https://work.kangdaejong.com/#person"}
    }
  ]
}
</script>
  </Fragment>

  <div class="lab-page" style="--page-accent: var(--warn)">
    <section class="lab-hero">
      <h1 class="logo">막다른 길</h1>
      <p class="tagline">dead ends · 막힌 시도들</p>
      <p class="intro">시도했지만 막힌 것들. 브라우저 자동화 차단, API 제한, 구조적 장벽 등 — 왜 안 됐는지 기록해두면 같은 벽에 두 번 부딪히지 않는다. 노하우(되는 것)·이슈(사건)와 분리된 실패 사례 모음.</p>
    </section>

    <div id="view"><div class="lab-loading">불러오는 중…</div></div>

    <a class="lab-back" href="/lab">← lab</a>
  </div>

  <script is:inline>
    const viewEl = document.getElementById('view');

    function escapeHtml(s) {
      return (s || '').replace(/[&<>"']/g, c => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      }[c]));
    }

    async function init() {
      try {
        const idxRes = await fetch('/dead-ends/index.json?_=' + Date.now());
        const idxData = await idxRes.json();
        const entries = (idxData.entries || [])
          .slice()
          .sort((a, b) => {
            if (a.date !== b.date) return b.date.localeCompare(a.date);
            return (a.slug || '').localeCompare(b.slug || '');
          });

        if (entries.length === 0) { viewEl.innerHTML = renderEmpty(); return; }
        render(entries);
      } catch (e) {
        viewEl.innerHTML = '<div class="lab-error">데이터를 불러오지 못했습니다.</div>';
      }
    }

    function renderEmpty() {
      return '<div class="lab-empty"><div style="font-size:32px;margin-bottom:12px;opacity:0.5;">🚧</div>' +
        '<div>아직 기록된 막다른 길이 없습니다.</div>' +
        '<div style="font-size:12px;color:var(--fg-mute);margin-top:6px;">시도했지만 막힌 사례가 생기면 여기 모입니다.</div></div>';
    }

    function render(items) {
      const total = items.length;
      const categories = new Set(items.map(it => it.category).filter(Boolean));

      let html = '<div class="lab-stats">';
      html += '<div class="lab-stat"><div class="lab-stat-label">누적 실패 사례</div>' +
        '<div class="lab-stat-value">' + total + '<span class="unit">건</span></div>' +
        '<div class="lab-stat-sub">두 번 부딪히지 않기 위한 기록</div></div>';
      html += '<div class="lab-stat"><div class="lab-stat-label">카테고리</div>' +
        '<div class="lab-stat-value">' + categories.size + '<span class="unit">개</span></div>' +
        '<div class="lab-stat-sub">영역별 막다른 길</div></div>';
      html += '</div>';

      html += '<div class="lab-list">';
      for (const it of items) {
        const slug = it.slug || (it.file || '').replace(/\.md$/, '');
        const href = slug ? './dead-ends/detail.html?slug=' + encodeURIComponent(slug) : '#';
        const tags = (it.tags || []).slice(0, 5);

        html += '<a class="lab-card" href="' + href + '">';
        html += '<div class="lab-card-head">';
        if (it.category) html += '<span class="lab-cat">' + escapeHtml(it.category) + '</span>';
        html += '<span class="lab-card-title">' + escapeHtml(it.title) + '</span>';
        html += '</div>';
        html += '<div class="lab-meta">' + escapeHtml(it.date || '');
        if (slug) html += '<span class="sep">|</span>' + escapeHtml(slug);
        html += '</div>';
        if (tags.length) {
          html += '<div class="lab-tags">';
          for (const t of tags) html += '<span class="lab-tag">' + escapeHtml(t) + '</span>';
          html += '</div>';
        }
        if (it.summary) html += '<div class="lab-summary">' + escapeHtml(it.summary) + '</div>';
        html += '</a>';
      }
      html += '</div>';
      viewEl.innerHTML = html;
    }

    init();
  </script>
</Layout>

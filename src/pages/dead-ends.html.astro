---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import Layout from '../layouts/Layout.astro';

type DeadEndEntry = {
  file?: string;
  slug?: string;
  title: string;
  date: string;
  category?: string;
  tags?: string[];
  summary?: string;
};

const indexPath = join(process.cwd(), 'public/dead-ends/index.json');
const indexData = JSON.parse(readFileSync(indexPath, 'utf-8')) as { entries?: DeadEndEntry[] };

const entries = (indexData.entries ?? [])
  .slice()
  .sort((a, b) => {
    if (a.date !== b.date) return b.date.localeCompare(a.date);
    return (a.slug ?? '').localeCompare(b.slug ?? '');
  });

const featured = entries.slice(0, 3);
const latestDate = entries[0]?.date ?? '—';
const categories = new Map<string, number>();

for (const entry of entries) {
  if (!entry.category) continue;
  categories.set(entry.category, (categories.get(entry.category) ?? 0) + 1);
}

const categoryRows = Array.from(categories.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => {
    if (a.count !== b.count) return b.count - a.count;
    return a.name.localeCompare(b.name);
  });

const monthMap = new Map<string, DeadEndEntry[]>();
for (const entry of entries) {
  const key = entry.date.slice(0, 7);
  if (!monthMap.has(key)) monthMap.set(key, []);
  monthMap.get(key)?.push(entry);
}
const monthGroups = Array.from(monthMap.entries()).map(([month, items]) => ({ month, items }));

const stats = [
  { label: '전체', value: `${entries.length}건` },
  { label: '분류', value: `${categoryRows.length}개` },
  { label: '최신', value: latestDate },
];

const hrefFor = (entry: DeadEndEntry) => {
  const slug = entry.slug || entry.file?.replace(/\.md$/, '');
  return slug ? `/dead-ends/detail.html?slug=${encodeURIComponent(slug)}` : '#';
};

const formatMonth = (month: string) => month.replace('-', '.');
---
<Layout title="막다른 길 — 마이너스베타스튜디오" description="시도했지만 막힌 작업을 모아둔 실패 사례 기록. 브라우저 자동화 차단, API 제한, 구조적 한계를 증상과 판단 근거, 포기 이유, 재시도 조건까지 남겨 다음 시도에서 같은 길을 피합니다.">
  <Fragment slot="head">
    <link rel="canonical" href="https://work.kangdaejong.com/dead-ends.html" />
    <script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://work.kangdaejong.com/#person",
      "name": "강대종",
      "jobTitle": "Solo founder / Vibe coder",
      "url": "https://work.kangdaejong.com/",
      "sameAs": ["https://github.com/ssamssae"],
      "description": "1인 개발자 / Vibe coder / Solo founder"
    },
    {
      "@type": "WebSite",
      "@id": "https://work.kangdaejong.com/#website",
      "name": "강대종",
      "url": "https://work.kangdaejong.com/",
      "inLanguage": "ko",
      "author": {"@id": "https://work.kangdaejong.com/#person"}
    }
  ]
}
    </script>
  </Fragment>

  <div class="dead-page">
    <section class="dead-hero" aria-labelledby="page-title">
      <div class="hero-copy">
        <p class="eyebrow">DEAD ENDS</p>
        <h1 id="page-title">막다른 길</h1>
        <p class="lead">
          시도했지만 접은 것들을 따로 남깁니다.
          안 되는 길을 지워두면 다음 작업은 더 빨리 좁혀집니다.
        </p>
      </div>
      <dl class="hero-stats" aria-label="막다른 길 요약">
        {stats.map((stat) => (
          <div>
            <dt>{stat.label}</dt>
            <dd>{stat.value}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="featured-section" aria-labelledby="featured-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">LATEST DROPS</p>
          <h2 id="featured-title">최근에 접은 길</h2>
        </div>
        <p>가장 최근 사례를 먼저 보여주고, 아래에는 월별 아카이브를 이어둡니다.</p>
      </div>

      <div class="featured-grid">
        {featured.map((entry, index) => (
          <a class={index === 0 ? 'dead-card primary' : 'dead-card'} href={hrefFor(entry)}>
            <span class="card-topline">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <span>{entry.date}</span>
            </span>
            <strong>{entry.title}</strong>
            {entry.summary && <span class="summary">{entry.summary}</span>}
            <span class="read-more">보기</span>
          </a>
        ))}
      </div>
    </section>

    <section class="category-section" aria-labelledby="category-title">
      <div class="section-head compact">
        <div>
          <p class="eyebrow">PATTERNS</p>
          <h2 id="category-title">막힌 유형</h2>
        </div>
      </div>

      <ol class="category-list">
        {categoryRows.map((category) => (
          <li>
            <span>{category.name}</span>
            <strong>{category.count}건</strong>
          </li>
        ))}
      </ol>
    </section>

    <section class="archive-section" aria-labelledby="archive-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">ARCHIVE</p>
          <h2 id="archive-title">전체 기록</h2>
        </div>
        <p>제목, 날짜, 분류, 태그를 한 줄 흐름으로 훑고 필요한 항목만 상세로 들어갑니다.</p>
      </div>

      <div class="archive-list">
        {monthGroups.map((group) => (
          <section class="month-block" aria-labelledby={`month-${group.month}`}>
            <header>
              <h3 id={`month-${group.month}`}>{formatMonth(group.month)}</h3>
              <span>{group.items.length}건</span>
            </header>
            <ol>
              {group.items.map((entry) => (
                <li>
                  <a href={hrefFor(entry)}>
                    <span class="archive-date">{entry.date}</span>
                    <span class="archive-body">
                      <strong>{entry.title}</strong>
                      <span class="archive-meta">
                        {entry.category && <em>{entry.category}</em>}
                        {(entry.tags ?? []).slice(0, 3).map((tag) => <small>{tag}</small>)}
                      </span>
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    </section>

    <a class="back-link" href="/lab">← lab</a>
  </div>

  <style>
    .dead-page {
      --dead-accent: #f59e0b;
      display: flex;
      flex-direction: column;
      gap: 56px;
    }

    .dead-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      gap: 40px;
      align-items: end;
      border-bottom: 1px solid var(--border);
      padding: 18px 0 40px;
    }

    .eyebrow {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0;
      margin-bottom: 12px;
    }

    h1 {
      color: var(--fg);
      font-size: clamp(48px, 8vw, 96px);
      line-height: 0.95;
      margin: 0 0 20px;
    }

    .lead {
      max-width: 640px;
      color: var(--fg-dim);
      font-size: 18px;
      line-height: 1.75;
      word-break: keep-all;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: 1fr;
      border-top: 1px solid var(--fg);
    }

    .hero-stats div {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 16px;
      align-items: baseline;
      border-bottom: 1px solid var(--border);
      min-height: 58px;
      padding: 14px 0;
    }

    .hero-stats dt {
      color: var(--fg-mute);
      font-size: 13px;
      font-weight: 600;
    }

    .hero-stats dd {
      min-width: 0;
      color: var(--fg);
      font-family: var(--mono);
      font-size: 16px;
      font-weight: 600;
      line-height: 1.45;
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      gap: 24px;
      align-items: end;
      margin-bottom: 20px;
    }

    .section-head.compact {
      display: block;
    }

    .section-head h2 {
      color: var(--fg);
      font-size: 24px;
      line-height: 1.25;
      word-break: keep-all;
    }

    .section-head > p {
      max-width: 380px;
      color: var(--fg-mute);
      font-size: 14px;
      line-height: 1.6;
      text-align: right;
      word-break: keep-all;
    }

    .featured-grid {
      display: grid;
      grid-template-columns: 1.08fr 0.96fr 0.96fr;
      gap: 16px;
    }

    .dead-card {
      display: flex;
      min-height: 258px;
      flex-direction: column;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg);
      color: var(--fg);
      padding: 22px;
      text-decoration: none;
    }

    .dead-card:hover {
      background: var(--bg-elev);
      color: var(--fg);
      text-decoration: none;
    }

    .dead-card.primary {
      border-color: transparent;
      background: var(--fg);
      color: var(--bg);
    }

    .dead-card.primary .card-topline,
    .dead-card.primary .summary,
    .dead-card.primary .read-more {
      color: rgba(255, 255, 255, 0.72);
    }

    .card-topline {
      display: flex;
      flex-direction: column;
      gap: 50px;
      margin-bottom: 14px;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .dead-card strong {
      color: inherit;
      font-size: 22px;
      line-height: 1.32;
      margin-bottom: 12px;
      word-break: keep-all;
    }

    .summary {
      color: var(--fg-dim);
      font-size: 14px;
      line-height: 1.7;
      word-break: keep-all;
    }

    .read-more {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 64px;
      height: 34px;
      margin-top: auto;
      border: 1px solid currentColor;
      border-radius: 999px;
      color: inherit;
      font-size: 13px;
      font-weight: 700;
    }

    .category-list {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
      list-style: none;
    }

    .category-list li {
      min-height: 96px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 18px;
    }

    .category-list span {
      display: block;
      margin-bottom: 16px;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .category-list strong {
      color: var(--fg);
      font-size: 20px;
      line-height: 1.25;
    }

    .archive-list {
      display: grid;
      gap: 28px;
    }

    .month-block {
      display: grid;
      grid-template-columns: 180px minmax(0, 1fr);
      gap: 24px;
      border-top: 1px solid var(--border);
      padding-top: 24px;
    }

    .month-block header {
      position: sticky;
      top: 96px;
      align-self: start;
    }

    .month-block h3 {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 20px;
      line-height: 1.25;
      margin-bottom: 6px;
    }

    .month-block header span {
      color: var(--fg-mute);
      font-size: 13px;
    }

    .month-block ol {
      border-top: 1px solid var(--border-soft);
      list-style: none;
    }

    .month-block li {
      border-bottom: 1px solid var(--border-soft);
    }

    .month-block a {
      display: grid;
      grid-template-columns: 116px minmax(0, 1fr);
      gap: 16px;
      align-items: baseline;
      min-height: 68px;
      padding: 14px 0;
      color: var(--fg);
      text-decoration: none;
    }

    .month-block a:hover {
      background: var(--bg-elev);
      color: var(--fg);
      text-decoration: none;
    }

    .archive-date {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
    }

    .archive-body {
      display: grid;
      gap: 8px;
      min-width: 0;
    }

    .archive-body strong {
      color: var(--fg);
      font-size: 16px;
      line-height: 1.45;
      word-break: keep-all;
    }

    .archive-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .archive-meta em,
    .archive-meta small {
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--fg-mute);
      font-size: 11px;
      font-style: normal;
      line-height: 1.4;
      padding: 2px 8px;
    }

    .archive-meta em {
      border-color: color-mix(in srgb, var(--dead-accent) 36%, var(--border));
      color: var(--fg-dim);
    }

    .back-link {
      align-self: flex-start;
      color: var(--fg-mute);
      font-size: 14px;
      text-decoration: none;
    }

    .back-link:hover {
      color: var(--fg);
    }

    @media (max-width: 920px) {
      .dead-hero,
      .featured-grid,
      .month-block {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 64px;
      }

      .lead {
        font-size: 16px;
      }

      .hero-stats {
        max-width: 520px;
      }

      .category-list {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .month-block header {
        position: static;
      }
    }

    @media (max-width: 640px) {
      .dead-page {
        gap: 48px;
      }

      .dead-hero {
        gap: 34px;
        padding-top: 8px;
      }

      h1 {
        font-size: 56px;
      }

      .hero-stats div,
      .month-block a {
        grid-template-columns: 1fr;
      }

      .section-head {
        display: block;
      }

      .section-head > p {
        margin-top: 10px;
        text-align: left;
      }

      .dead-card {
        min-height: 220px;
        padding: 20px;
      }

      .card-topline {
        gap: 36px;
      }

      .category-list {
        grid-template-columns: 1fr;
      }

      .month-block {
        gap: 16px;
      }

      .month-block a {
        gap: 4px;
        min-height: auto;
        padding: 14px 0;
      }
    }
  </style>
</Layout>

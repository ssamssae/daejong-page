  <script is:inline>
    (function() {
      var list = document.querySelector('.list');
      var btn = document.getElementById('sort-toggle');
      var KEY = 'habits-sort-desc';
      function apply(desc) {
        var cards = Array.from(list.children);
        cards.sort(function(a, b) {
          var na = parseInt(a.querySelector('.hb-num').textContent, 10);
          var nb = parseInt(b.querySelector('.hb-num').textContent, 10);
          return desc ? nb - na : na - nb;
        });
        cards.forEach(function(c) { list.appendChild(c); });
        if (cards.length === 0) { btn.textContent = '정렬'; return; }
        var first = cards[0].querySelector('.hb-num').textContent.trim();
        var last = cards[cards.length - 1].querySelector('.hb-num').textContent.trim();
        btn.textContent = '정렬: ' + first + ' → ' + last;
      }
      var desc = localStorage.getItem(KEY) !== '0';
      apply(desc);
      btn.addEventListener('click', function() {
        desc = !desc;
        localStorage.setItem(KEY, desc ? '1' : '0');
        apply(desc);
      });
    })();
  </script>

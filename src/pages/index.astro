---
import Layout from '../layouts/Layout.astro';
import PostList from '../components/PostList.astro';
import ActivityCard from '../components/ActivityCard.astro';
import { getCollection } from 'astro:content';

const allWorklog = (await getCollection('worklog')).sort((a, b) =>
  b.data.date.localeCompare(a.data.date) || (b.data.version ?? '').localeCompare(a.data.version ?? '')
);
const recentWorklog = allWorklog.slice(0, 5);

const epNum = (entry) => parseInt(String(entry.id).replace(/\D/g, ''), 10) || 0;
const allNewsletter = (await getCollection('newsletter')).sort((a, b) => epNum(b) - epNum(a));
const recentNewsletter = allNewsletter.slice(0, 4);

const stats = [
  { label: '제품', value: '10', detail: '앱 7 · 도구 2 · SaaS 1' },
  { label: '작업일지', value: allWorklog.length, detail: '매일의 빌드 로그' },
  { label: '뉴스레터', value: `Ep.${epNum(allNewsletter[0])}`, detail: `총 ${allNewsletter.length}편` },
];

const routes = [
  { href: '/products/', label: '01', kicker: 'PRODUCTS', title: '제품', desc: '공개한 모바일 앱, 오픈소스 도구, 준비 중인 웹 SaaS를 한 화면에서 봅니다.' },
  { href: '/worklog/', label: '02', kicker: 'WORKLOG', title: '작업일지', desc: '하루 단위로 무엇을 만들고 고쳤는지 남긴 빌드 로그입니다.' },
  { href: '/newsletter/', label: '03', kicker: 'NEWSLETTER', title: '뉴스레터', desc: '바이브코딩과 1인 앱 제작 과정을 에피소드로 정리합니다.' },
  { href: '/insights/', label: '04', kicker: 'INSIGHTS', title: '인사이트', desc: '영상과 아티클에서 뽑은 학습 노트를 모아둡니다.' },
  { href: '/system/', label: '05', kicker: 'SYSTEM', title: '시스템', desc: '물리 노드와 자동화 스택의 구조를 기록합니다.' },
  { href: '/lab/', label: '06', kicker: 'LAB', title: 'lab', desc: '실험, 잡학, 접은 시도까지 작업의 주변부를 보관합니다.' },
];

const loop = [
  {
    label: 'BUILD',
    title: '작게 만든다',
    desc: '모바일 앱, 웹 서비스, 자동화 도구를 작은 단위로 만들고 실제 공개 상태까지 밀어붙입니다.',
  },
  {
    label: 'LOG',
    title: '과정을 남긴다',
    desc: '선택, 실패, 수정 이유를 작업일지와 뉴스레터에 남겨 다음 작업의 입력으로 씁니다.',
  },
  {
    label: 'REFINE',
    title: '다시 다듬는다',
    desc: '사용 중 발견한 마찰을 제품, 운영 자동화, 공개 도구로 되돌려 보냅니다.',
  },
];

const bridgeProjects = [
  {
    name: 'Codex Telegram Bridge',
    status: 'PUBLIC · v0.5.5',
    desc: 'Codex CLI REPL을 텔레그램에서 제어하는 전용 브릿지. 텍스트·이미지·영상·음성·파일 입력과 진행 미러를 지원합니다.',
    repo: 'https://github.com/ssamssae/codex-telegram-bridge',
    release: 'https://github.com/ssamssae/codex-telegram-bridge/releases/tag/v0.5.5',
  },
  {
    name: 'Claude Telegram Bridge',
    status: 'PUBLIC · v0.4.2',
    desc: 'Claude Code live tmux 세션을 텔레그램으로 연결하는 전용 브릿지. 세션 주입, transcript 추출, 미디어 local_path 전달로 동작합니다.',
    repo: 'https://github.com/ssamssae/claude-telegram-bridge',
    release: 'https://github.com/ssamssae/claude-telegram-bridge/releases/tag/v0.4.2',
  },
];
---
<Layout title="강대종의 작업장 — work.kangdaejong.com" description="강대종의 작업장. 제품·오픈소스 도구·작업일지·뉴스레터·인사이트·자동화 스택을 한 곳에서 보는 허브.">
  <div class="home" data-tone="workshop-index">
    <section class="home-hero" aria-labelledby="home-title">
      <div class="hero-copy">
        <p class="eyebrow">PUBLIC WORKSHOP</p>
        <h1 id="home-title">작게 만들고, 매일 남깁니다.</h1>
        <p class="lead">
          강대종이 만든 앱, 오픈소스 도구, 자동화 시스템과 그 과정을 모은 공개 작업장입니다.
          제품은 작게 공개하고 기록은 다음 빌드를 위해 남깁니다.
        </p>
        <div class="hero-actions" aria-label="주요 이동">
          <a class="button primary" href="/products/">제품 보기</a>
          <a class="button secondary" href="/worklog/">작업일지 보기</a>
        </div>
      </div>

      <dl class="hero-stats" aria-label="작업장 요약">
        {stats.map((stat) => (
          <div>
            <dt>{stat.label}</dt>
            <dd>{stat.value}</dd>
            <span>{stat.detail}</span>
          </div>
        ))}
      </dl>
    </section>

    <section class="route-section" aria-labelledby="routes-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">INDEX</p>
          <h2 id="routes-title">들어갈 곳을 고릅니다.</h2>
        </div>
        <p>제품, 기록, 시스템을 같은 톤의 인덱스로 묶었습니다.</p>
      </div>

      <div class="route-grid">
        {routes.map((route) => (
          <a class="route-card" href={route.href}>
            <span class="route-top">
              <span>{route.label}</span>
              <span>{route.kicker}</span>
            </span>
            <strong>{route.title}</strong>
            <span>{route.desc}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="loop-section" aria-labelledby="loop-title">
      <div class="section-head compact">
        <div>
          <p class="eyebrow">WORK LOOP</p>
          <h2 id="loop-title">작업장은 세 단계로 굴러갑니다.</h2>
        </div>
      </div>

      <ol class="loop-list">
        {loop.map((item) => (
          <li>
            <span>{item.label}</span>
            <strong>{item.title}</strong>
            <p>{item.desc}</p>
          </li>
        ))}
      </ol>
    </section>

    <ActivityCard />

    <section class="bridge-section" aria-labelledby="bridge-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">OPEN SOURCE</p>
          <h2 id="bridge-title">폰에서 AI 작업장을 다루기 위해 만든 브릿지</h2>
        </div>
        <p>개인 운영에서 출발했지만 공개 저장소와 릴리스로 관리합니다.</p>
      </div>

      <div class="bridge-grid">
        {bridgeProjects.map((project, index) => (
          <article class={index === 0 ? 'bridge-card primary' : 'bridge-card'}>
            <div class="bridge-card-top">
              <h3>{project.name}</h3>
              <span>{project.status}</span>
            </div>
            <p>{project.desc}</p>
            <div class="bridge-links">
              <a href={project.repo} target="_blank" rel="noopener">GitHub</a>
              <a href={project.release} target="_blank" rel="noopener">Release</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="recent-grid" aria-label="최근 기록">
      <article class="recent-panel">
        <div class="recent-head">
          <div>
            <p class="eyebrow">RECENT LOG</p>
            <h2>최근 작업일지</h2>
          </div>
          <a href="/worklog/">전체 보기</a>
        </div>
        <PostList posts={recentWorklog} base="/worklog" />
      </article>

      <article class="recent-panel">
        <div class="recent-head">
          <div>
            <p class="eyebrow">NEWSLETTER</p>
            <h2>최근 뉴스레터</h2>
          </div>
          <a href="/newsletter/">전체 보기</a>
        </div>
        <PostList posts={recentNewsletter} base="/newsletter" />
      </article>
    </section>
  </div>

  <style>
    .home {
      display: flex;
      flex-direction: column;
      gap: 76px;
    }

    .home-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 420px);
      gap: 48px;
      align-items: end;
      border-bottom: 1px solid var(--border);
      padding: 18px 0 42px;
    }

    .eyebrow {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0;
      margin-bottom: 12px;
    }

    .hero-copy h1 {
      max-width: 760px;
      font-size: 64px;
      line-height: 1.02;
      word-break: keep-all;
    }

    .lead {
      max-width: 680px;
      margin-top: 24px;
      color: var(--fg-dim);
      font-size: 20px;
      line-height: 1.7;
      word-break: keep-all;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 34px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 18px;
      border: 1px solid var(--fg);
      border-radius: 8px;
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
    }

    .button:hover {
      text-decoration: none;
    }

    .button.primary {
      border-color: var(--accent-cta);
      background: var(--accent-cta);
      color: #ffffff;
    }

    .button.primary:hover {
      border-color: var(--accent-dim);
      background: var(--accent-dim);
      color: #ffffff;
    }

    .button.secondary {
      background: var(--bg);
      color: var(--fg);
    }

    .button.secondary:hover {
      background: var(--bg-elev);
      color: var(--fg);
    }

    .hero-stats {
      display: grid;
      border-top: 1px solid var(--border);
    }

    .hero-stats div {
      display: grid;
      grid-template-columns: 84px minmax(0, 1fr);
      gap: 12px 20px;
      align-items: baseline;
      padding: 20px 0;
      border-bottom: 1px solid var(--border);
    }

    .hero-stats dt {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .hero-stats dd {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 16px;
      font-weight: 700;
      line-height: 1.45;
      min-width: 0;
    }

    .hero-stats span {
      grid-column: 2;
      color: var(--fg-dim);
      font-size: 13px;
      line-height: 1.45;
      white-space: nowrap;
    }

    .section-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(220px, 360px);
      gap: 32px;
      align-items: end;
      margin-bottom: 24px;
    }

    .section-head.compact {
      display: block;
      margin-bottom: 12px;
    }

    .section-head h2 {
      max-width: 720px;
      font-size: 34px;
      line-height: 1.2;
      word-break: keep-all;
    }

    .section-head > p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.6;
    }

    .route-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
    }

    .route-card {
      display: grid;
      gap: 16px;
      min-height: 218px;
      padding: 22px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      color: var(--fg);
      text-decoration: none;
    }

    .route-card:hover {
      background: var(--bg-elev);
      color: var(--fg);
      text-decoration: none;
    }

    .route-top {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .route-card strong {
      font-size: 24px;
      line-height: 1.2;
    }

    .route-card > span:last-child {
      align-self: end;
      color: var(--fg-dim);
      font-size: 14px;
      line-height: 1.6;
    }

    .loop-list {
      border-top: 1px solid var(--border);
      list-style: none;
    }

    .loop-list li {
      display: grid;
      grid-template-columns: 120px minmax(180px, 260px) minmax(0, 1fr);
      gap: 24px;
      align-items: baseline;
      padding: 22px 0;
      border-bottom: 1px solid var(--border);
    }

    .loop-list span {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .loop-list strong {
      color: var(--fg);
      font-size: 22px;
      line-height: 1.25;
    }

    .loop-list p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.65;
    }

    .bridge-grid {
      display: grid;
      grid-template-columns: 1.08fr 0.92fr;
      gap: 16px;
    }

    .bridge-card {
      display: grid;
      align-content: start;
      gap: 20px;
      min-height: 260px;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 24px;
      background: var(--bg);
    }

    .bridge-card.primary {
      background: var(--fg);
      color: var(--bg);
    }

    .bridge-card.primary p,
    .bridge-card.primary .bridge-card-top span,
    .bridge-card.primary a {
      color: rgba(255, 255, 255, 0.74);
    }

    .bridge-card-top {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: flex-start;
    }

    .bridge-card h3 {
      font-size: 25px;
      line-height: 1.18;
    }

    .bridge-card-top span {
      flex: 0 0 auto;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      white-space: nowrap;
    }

    .bridge-card p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.68;
    }

    .bridge-links {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: auto;
      font-size: 14px;
      font-weight: 700;
    }

    .recent-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 48px;
      padding-top: 32px;
      border-top: 1px solid var(--border);
    }

    .recent-panel {
      min-width: 0;
    }

    .recent-head {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      align-items: flex-start;
      margin-bottom: 14px;
    }

    .recent-head h2 {
      font-size: 28px;
      line-height: 1.18;
    }

    .recent-head a {
      flex: 0 0 auto;
      margin-top: 4px;
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
    }

    .recent-head a:hover {
      text-decoration: underline;
    }

    @media (max-width: 920px) {
      .home {
        gap: 64px;
      }

      .home-hero,
      .section-head,
      .bridge-grid,
      .recent-grid {
        grid-template-columns: 1fr;
      }

      .hero-copy h1 {
        font-size: 48px;
      }

      .lead {
        font-size: 18px;
      }

      .route-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .home {
        gap: 54px;
      }

      .home-hero {
        gap: 34px;
        padding-top: 10px;
      }

      .hero-copy h1 {
        font-size: 38px;
      }

      .lead {
        font-size: 16px;
      }

      .hero-actions {
        flex-direction: column;
      }

      .button {
        width: 100%;
      }

      .hero-stats div,
      .loop-list li,
      .route-grid {
        grid-template-columns: 1fr;
      }

      .hero-stats span {
        grid-column: auto;
        white-space: normal;
      }

      .section-head h2 {
        font-size: 28px;
      }

      .route-card {
        min-height: 178px;
        padding: 18px;
      }

      .bridge-card {
        min-height: auto;
        padding: 20px;
      }

      .bridge-card-top,
      .recent-head {
        display: block;
      }

      .bridge-card-top span,
      .recent-head a {
        display: inline-flex;
        margin-top: 8px;
      }
    }
  </style>
</Layout>

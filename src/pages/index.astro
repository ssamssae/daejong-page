---
import Layout from '../layouts/Layout.astro';
import SectionCard from '../components/SectionCard.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';

const recentWorklog = (await getCollection('worklog'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date) || (b.data.version ?? '').localeCompare(a.data.version ?? ''))
  .slice(0, 5);
const epNum = (e) => parseInt(String(e.id).replace(/\D/g, ''), 10) || 0;
const recentNewsletter = (await getCollection('newsletter'))
  .sort((a, b) => epNum(b) - epNum(a))
  .slice(0, 3);

const sections = [
  { href: '/about', title: 'about', desc: '강대종 소개서. 만드는 방식과 작업장으로 이어지는 링크.', accent: 'magenta' },
  { href: '/products/', title: 'products', desc: '공개한 모바일 앱과 준비 중인 웹 SaaS.', accent: 'cyan' },
  { href: '/worklog', title: 'worklog', desc: '매일의 빌드로그. AI와 함께 만드는 과정 기록.', accent: 'magenta' },
  { href: '/newsletter', title: 'newsletter', desc: '바이브코딩 — 1인 앱 제작 여정 격주 발행.', accent: 'cyan' },
  { href: '/insights', title: 'insights', desc: '영상·아티클에서 뽑은 학습 노트.', accent: 'magenta' },
  { href: '/system', title: 'system', desc: '물리 5대 · 논리 10노드 자동화 스택.', accent: 'cyan' },
  { href: '/lab', title: 'lab', desc: '잡학·실험·접은 시도들의 기록.', accent: 'magenta' },
];

const bridgeProjects = [
  {
    name: 'Codex Telegram Bridge',
    status: 'PUBLIC · v0.3.23',
    desc: 'Codex CLI REPL을 텔레그램에서 제어하는 전용 브릿지. 텍스트·이미지·영상·음성·파일 입력, 진행보고, reasoning mirror, typing recovery를 지원합니다.',
    repo: 'https://github.com/ssamssae/codex-telegram-bridge',
    release: 'https://github.com/ssamssae/codex-telegram-bridge/releases/tag/v0.3.23',
    accent: 'cyan',
  },
  {
    name: 'Claude Telegram Bridge',
    status: 'PUBLIC · v0.1.0',
    desc: 'Claude Code live tmux 세션을 텔레그램으로 연결하는 전용 브릿지. claude -p 없이 세션 주입·transcript 추출·미디어 local_path 전달로 동작합니다.',
    repo: 'https://github.com/ssamssae/claude-telegram-bridge',
    release: 'https://github.com/ssamssae/claude-telegram-bridge/releases/tag/v0.1.0',
    accent: 'magenta',
  },
];
---
<Layout title="작업장 — 마이너스베타스튜디오" description="마이너스베타스튜디오 작업장. 제품·작업일지·뉴스레터·인사이트·자동화 스택을 한 곳에서 보는 허브.">
  <section class="hero">
    <div class="logo"><img src="/minusbeta-badge.svg" alt="마이너스베타스튜디오" width="88" height="88" /></div>
    <h1>작업장</h1>
    <p class="tagline">마이너스베타스튜디오의 제품·기록·자동화 허브</p>
    <p class="intro">
      Claude 5 + Codex 5 논리 10노드 자동화 메시로 모바일 앱과 웹 서비스, 오픈소스 도구를 만들고,
      그 과정을 작업일지·뉴스레터·인사이트로 기록합니다.
    </p>
  </section>

  <section class="bridge-feature" aria-labelledby="bridge-feature-title">
    <div class="bridge-head">
      <p class="bridge-kicker">open source tools</p>
      <h2 id="bridge-feature-title">Telegram Bridges</h2>
      <p>폰에서 Codex와 Claude를 직접 다루기 위해 만든 두 개의 공개 브릿지.</p>
    </div>
    <div class="bridge-grid">
      {bridgeProjects.map((p) => (
        <article class={`bridge-card bridge-card--${p.accent}`}>
          <div class="bridge-card-top">
            <h3>{p.name}</h3>
            <span>{p.status}</span>
          </div>
          <p>{p.desc}</p>
          <div class="bridge-links">
            <a href={p.repo} target="_blank" rel="noopener">GitHub</a>
            <a href={p.release} target="_blank" rel="noopener">Release</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="sections">
    {sections.map((s) => <SectionCard href={s.href} title={s.title} desc={s.desc} accent={s.accent} />)}
  </section>

  <section class="recent">
    <div class="recent-head">
      <h2 class="accent-magenta">최근 작업일지</h2>
      <a href="/worklog">전체 →</a>
    </div>
    <PostList posts={recentWorklog} base="/worklog" />
  </section>

  <section class="recent">
    <div class="recent-head">
      <h2 class="accent-cyan">최근 뉴스레터</h2>
      <a href="/newsletter">전체 →</a>
    </div>
    <PostList posts={recentNewsletter} base="/newsletter" />
  </section>

  <style>
    .hero { text-align: center; padding: 24px 0 48px; }
    .logo img { height: 88px; width: 88px; display: block; margin: 0 auto; }
    .hero h1 { font-size: 30px; margin-top: 12px; }
    .tagline { font-family: var(--mono); font-size: 14px; color: var(--magenta); margin-top: 8px; }
    .tagline .home-link { color: var(--cyan); }
    .tagline .home-link:hover { color: var(--magenta); }
    .intro { color: var(--fg-dim); max-width: 540px; margin: 20px auto 0; font-size: 15px; }
    .bridge-feature { margin: 0 0 48px; }
    .bridge-head { margin-bottom: 14px; }
    .bridge-kicker { font-family: var(--mono); font-size: 11px; color: var(--fg-mute); text-transform: uppercase; letter-spacing: 0; }
    .bridge-head h2 { font-family: var(--mono); font-size: 20px; line-height: 1.25; margin-top: 4px; color: var(--fg); }
    .bridge-head p:not(.bridge-kicker) { color: var(--fg-dim); font-size: 13px; margin-top: 6px; line-height: 1.55; }
    .bridge-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .bridge-card {
      border: 1px solid var(--border); border-radius: 10px; padding: 18px;
      background: var(--bg-elev); transition: border-color .15s;
    }
    .bridge-card--cyan:hover { border-color: var(--cyan); }
    .bridge-card--magenta:hover { border-color: var(--magenta); }
    .bridge-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
    .bridge-card h3 { font-family: var(--mono); font-size: 15px; line-height: 1.35; color: var(--cyan); }
    .bridge-card--magenta h3 { color: var(--magenta); }
    .bridge-card-top span { flex: 0 0 auto; font-family: var(--mono); font-size: 10px; color: var(--fg-mute); line-height: 1.35; padding-top: 2px; }
    .bridge-card p { color: var(--fg-dim); font-size: 13px; line-height: 1.6; margin: 12px 0; }
    .bridge-links { display: flex; gap: 14px; flex-wrap: wrap; font-family: var(--mono); font-size: 13px; }
    .bridge-links a { color: var(--fg-dim); }
    .bridge-card--cyan .bridge-links a:hover { color: var(--cyan); }
    .bridge-card--magenta .bridge-links a:hover { color: var(--magenta); }
    .sections { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin: 16px 0 56px; }
    .recent { margin-bottom: 48px; }
    .recent-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 12px; }
    .recent-head h2 { font-size: 18px; }
    .recent-head a { font-family: var(--mono); font-size: 12px; color: var(--fg-dim); }
    @media (max-width: 620px) {
      .bridge-grid { grid-template-columns: 1fr; }
      .bridge-card-top { display: block; }
      .bridge-card-top span { display: block; margin-top: 5px; }
    }
    @media (max-width: 520px) { .sections { grid-template-columns: 1fr; } }
  </style>
</Layout>

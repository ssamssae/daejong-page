---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const sectionTitles = Array.from((post.body ?? '').matchAll(/^##\s+(.+)$/gm))
  .map((match) => match[1])
  .slice(0, 6);
const sectionCount = sectionTitles.length;
---
<Layout title={`${post.data.title} — 인사이트`} description={post.data.summary ?? post.data.title}>
  <a class="back" href="/insights">← 인사이트 목록</a>
  <article class="insight-detail">
    <header class="detail-hero">
      <div class="hero-copy">
        <p class="eyebrow">INSIGHT NOTE</p>
        <h1>{post.data.title}</h1>
        {post.data.summary && <p class="lead">{post.data.summary}</p>}
      </div>
      <dl class="detail-facts" aria-label="인사이트 정보">
        <div>
          <dt>날짜</dt>
          <dd>{post.data.date}</dd>
        </div>
        <div>
          <dt>분류</dt>
          <dd>인사이트</dd>
        </div>
        <div>
          <dt>섹션</dt>
          <dd>{sectionCount}개</dd>
        </div>
      </dl>
    </header>

    <div class="article-body">
      {sectionTitles.length > 0 && (
        <aside class="section-rail" aria-label="본문 섹션">
          <p>SECTIONS</p>
          <ol>
            {sectionTitles.map((title, index) => (
              <li>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{title}</strong>
              </li>
            ))}
          </ol>
        </aside>
      )}
      <div class="prose detail-prose"><Content /></div>
    </div>
  </article>
  <style>
    .back {
      color: var(--fg-dim);
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
    }

    .back:hover {
      color: var(--fg);
      text-decoration: underline;
      text-decoration-thickness: 1px;
    }

    .insight-detail {
      margin-top: 22px;
    }

    .detail-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 340px);
      gap: 48px;
      align-items: end;
      border-bottom: 1px solid var(--border);
      padding: 22px 0 44px;
      margin-bottom: 44px;
    }

    .eyebrow {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0;
      margin-bottom: 12px;
    }

    h1 {
      max-width: 860px;
      color: var(--fg);
      font-size: 56px;
      line-height: 1.08;
      margin: 0;
      word-break: keep-all;
    }

    .lead {
      max-width: 680px;
      color: var(--fg-dim);
      font-size: 18px;
      line-height: 1.75;
      margin-top: 22px;
      word-break: keep-all;
    }

    .detail-facts {
      display: grid;
      border-top: 1px solid var(--fg);
    }

    .detail-facts div {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 16px;
      align-items: baseline;
      min-height: 56px;
      border-bottom: 1px solid var(--border);
      padding: 14px 0;
    }

    .detail-facts dt {
      color: var(--fg-mute);
      font-size: 13px;
      font-weight: 600;
    }

    .detail-facts dd {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 15px;
      font-weight: 600;
      line-height: 1.45;
      min-width: 0;
    }

    .article-body {
      display: grid;
      grid-template-columns: 180px minmax(0, 760px);
      gap: 48px;
      align-items: start;
    }

    .section-rail {
      position: sticky;
      top: 96px;
      border-top: 1px solid var(--border);
      padding-top: 16px;
    }

    .section-rail p {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 14px;
    }

    .section-rail ol {
      display: grid;
      gap: 14px;
      list-style: none;
    }

    .section-rail li {
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 12px;
      align-items: baseline;
    }

    .section-rail span {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .section-rail strong {
      color: var(--fg);
      font-size: 14px;
      font-weight: 600;
      line-height: 1.45;
      word-break: keep-all;
    }

    .detail-prose {
      min-width: 0;
      max-width: 760px;
      font-size: 16px;
      line-height: 1.85;
    }

    .detail-prose :global(h1:first-child) {
      display: none;
    }

    .detail-prose :global(h2) {
      border-top: 1px solid var(--border-soft);
      color: var(--fg);
      font-size: 24px;
      line-height: 1.3;
      margin: 52px 0 14px;
      padding-top: 24px;
    }

    .detail-prose :global(h2:first-of-type) {
      margin-top: 0;
    }

    .detail-prose :global(h3) {
      color: var(--fg);
      font-size: 18px;
      line-height: 1.35;
      margin-top: 34px;
    }

    .detail-prose :global(p),
    .detail-prose :global(li) {
      color: var(--fg-dim);
      word-break: keep-all;
    }

    .detail-prose :global(ul),
    .detail-prose :global(ol) {
      padding-left: 20px;
    }

    .detail-prose :global(li) {
      margin: 8px 0;
      padding-left: 2px;
    }

    .detail-prose :global(strong) {
      color: var(--fg);
    }

    .detail-prose :global(a) {
      color: var(--fg);
      font-weight: 600;
      text-decoration-thickness: 1px;
    }

    @media (max-width: 920px) {
      .detail-hero,
      .article-body {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 42px;
      }

      .lead {
        font-size: 16px;
      }

      .detail-facts {
        max-width: 520px;
      }

      .section-rail {
        position: static;
      }

      .section-rail ol {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .insight-detail {
        margin-top: 18px;
      }

      .detail-hero {
        gap: 34px;
        padding: 12px 0 36px;
        margin-bottom: 36px;
      }

      h1 {
        font-size: 32px;
      }

      .detail-facts div {
        grid-template-columns: 1fr;
      }

      .article-body {
        gap: 36px;
      }

      .section-rail {
        display: none;
      }

      .detail-prose {
        font-size: 15px;
      }

      .detail-prose :global(h2) {
        font-size: 22px;
        margin-top: 44px;
      }
    }
  </style>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import PostList from '../../components/PostList.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('insights')).sort((a, b) =>
  b.data.date.localeCompare(a.data.date)
);
---
<Layout title="인사이트 — 마이너스베타스튜디오" description="영상·아티클에서 뽑은 학습 노트 (second brain).">
  <h1 class="accent-magenta">인사이트</h1>
  <p class="lead">영상·아티클에서 뽑은 학습 노트 · 총 {posts.length}편</p>
  <PostList posts={posts} base="/insights" />
  <style>
    h1 { font-size: 32px; margin-bottom: 8px; }
    .lead { color: var(--fg-dim); font-family: var(--mono); font-size: 13px; margin-bottom: 32px; }
  </style>
</Layout>

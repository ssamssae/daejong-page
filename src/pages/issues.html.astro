---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import Layout from '../layouts/Layout.astro';

type IssueEntry = {
  file: string;
  date: string;
  slug: string;
  title: string;
  severity?: string | null;
  recurrence?: string | null;
  scope?: string | null;
  occurred_at?: string | null;
  resolved_at?: string | null;
  updated?: string | null;
};

const issuesIndex = JSON.parse(readFileSync(join(process.cwd(), 'public/issues/index.json'), 'utf-8')) as {
  entries: IssueEntry[];
};

const issues = issuesIndex.entries
  .slice()
  .sort((a, b) => b.date.localeCompare(a.date) || a.title.localeCompare(b.title, 'ko'));

const latestIssues = issues.slice(0, 6);
const monthGroups = issues.reduce((groups, issue) => {
  const month = issue.date?.slice(0, 7) || '날짜 미상';
  if (!groups.has(month)) groups.set(month, []);
  groups.get(month)?.push(issue);
  return groups;
}, new Map<string, IssueEntry[]>());

const dates = Array.from(new Set(issues.map((issue) => issue.date).filter(Boolean))).sort();
const latestUpdate =
  issues
    .map((issue) => issue.updated)
    .filter((value): value is string => Boolean(value))
    .sort()
    .at(-1) ?? issues[0]?.date ?? '';

const highSeverity = issues.filter((issue) => String(issue.severity ?? '').toLowerCase() === 'high').length;
const highRecurrence = issues.filter((issue) => String(issue.recurrence ?? '').toLowerCase() === 'high').length;

const dateLabel = (date?: string | null) => (date ? date.slice(0, 10).replaceAll('-', '.') : '-');
const monthLabel = (month: string) => {
  if (month === '날짜 미상') return month;
  const [year, mm] = month.split('-');
  return `${year}.${mm}`;
};
const levelText = (level?: string | null) => {
  const value = String(level ?? '').trim();
  if (!value || value === '?') return 'unknown';
  const lowered = value.toLowerCase();
  if (lowered.startsWith('high')) return 'high';
  if (lowered.startsWith('medium') || lowered.startsWith('mid')) return 'medium';
  if (lowered.startsWith('low')) return 'low';
  return 'unknown';
};
const badgeClass = (kind: 'severity' | 'recurrence', level?: string | null) => {
  const value = levelText(level).toLowerCase();
  return `${kind}-badge ${kind}-${value}`;
};
---

<Layout
  title="이슈 — 마이너스베타스튜디오"
  description="발생했다가 해결한 이슈와 혼선의 포스트모템 목록. 증상, 원인, 조치, 예방을 날짜별로 추적합니다."
>
  <Fragment slot="head">
    <meta property="og:title" content="이슈 — 마이너스베타스튜디오" />
    <meta property="og:description" content="발생했다가 해결한 이슈와 혼선의 포스트모템 기록." />
    <meta property="og:image" content="https://work.kangdaejong.com/og-default.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://work.kangdaejong.com/issues.html" />
    <meta property="og:site_name" content="강대종 작업장" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="이슈 — 마이너스베타스튜디오" />
    <meta name="twitter:description" content="발생했다가 해결한 이슈와 혼선의 포스트모템 기록." />
    <meta name="twitter:image" content="https://work.kangdaejong.com/og-default.png" />
    <link rel="canonical" href="https://work.kangdaejong.com/issues.html" />
  </Fragment>

  <article class="issues-page">
    <section class="issues-hero" aria-labelledby="page-title">
      <div class="hero-copy">
        <p class="eyebrow">POSTMORTEM LEDGER</p>
        <h1 id="page-title">이슈</h1>
        <p class="lead">
          발생했다가 해결한 문제를 숨기지 않고 남깁니다. 증상, 원인, 조치, 재발 가능성을
          날짜별로 모아 다음 작업의 안전장치로 씁니다.
        </p>
      </div>
      <dl class="hero-stats" aria-label="이슈 기록 요약">
        <div>
          <dt>기록</dt>
          <dd>{issues.length}</dd>
        </div>
        <div>
          <dt>날짜</dt>
          <dd>{dates.length}</dd>
        </div>
        <div>
          <dt>범위</dt>
          <dd>{dates.length ? `${dateLabel(dates[0])} - ${dateLabel(dates.at(-1))}` : '-'}</dd>
        </div>
      </dl>
    </section>

    <section class="signal-section" aria-labelledby="signal-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">CURRENT SIGNALS</p>
          <h2 id="signal-title">지금 먼저 봐야 하는 숫자</h2>
        </div>
        <p>심각도와 재발 가능성이 높은 항목은 포스트모템보다 운영 규칙으로 옮겨야 합니다.</p>
      </div>
      <div class="signal-grid">
        <div>
          <span>severity high</span>
          <strong>{highSeverity}</strong>
          <p>사용자 영향이나 작업 중단 가능성이 컸던 기록</p>
        </div>
        <div>
          <span>recurrence high</span>
          <strong>{highRecurrence}</strong>
          <p>기억이 아니라 강제 장치로 막아야 하는 기록</p>
        </div>
        <div>
          <span>latest update</span>
          <strong>{dateLabel(latestUpdate)}</strong>
          <p>index 기준 마지막 최신화 날짜</p>
        </div>
      </div>
    </section>

    <section class="latest-section" aria-labelledby="latest-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">LATEST</p>
          <h2 id="latest-title">최근 이슈</h2>
        </div>
        <p>가장 최근에 올라온 포스트모템을 먼저 확인합니다.</p>
      </div>
      <div class="latest-grid">
        {latestIssues.map((issue, index) => (
          <a class={index === 0 ? 'issue-card primary' : 'issue-card'} href={`/issues/${issue.file}`}>
            <span class="card-top">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <time datetime={issue.date}>{dateLabel(issue.date)}</time>
            </span>
            <h3>{issue.title}</h3>
            {issue.scope && <p>{issue.scope}</p>}
            <span class="badge-row">
              <span class={badgeClass('severity', issue.severity)}>심각도 {levelText(issue.severity)}</span>
              <span class={badgeClass('recurrence', issue.recurrence)}>재발 {levelText(issue.recurrence)}</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="archive-section" aria-labelledby="archive-title">
      <div class="section-head archive-head">
        <div>
          <p class="eyebrow">ARCHIVE</p>
          <h2 id="archive-title">전체 기록</h2>
        </div>
        <p>{monthGroups.size}개월치 이슈를 최신순으로 묶었습니다.</p>
      </div>

      <div class="archive-list">
        {Array.from(monthGroups.entries()).map(([month, items]) => (
          <section class="month-block" aria-labelledby={`month-${month}`}>
            <header>
              <h3 id={`month-${month}`}>{monthLabel(month)}</h3>
              <span>{items.length}건</span>
            </header>
            <ol>
              {items.map((issue) => (
                <li>
                  <a href={`/issues/${issue.file}`}>
                    <time datetime={issue.date}>{dateLabel(issue.date)}</time>
                    <span>{issue.title}</span>
                    <small>{levelText(issue.severity)} / {levelText(issue.recurrence)}</small>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    </section>

    <footer class="issues-footer">
      <p>마지막 갱신 {dateLabel(latestUpdate)}</p>
      <a href="/lab/">lab으로 돌아가기</a>
    </footer>
  </article>

  <style>
    .issues-page {
      display: flex;
      flex-direction: column;
      gap: 64px;
      min-width: 0;
    }

    .issues-page > * {
      min-width: 0;
    }

    .issues-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      gap: 40px;
      align-items: end;
      border-bottom: 1px solid var(--border);
      padding: 18px 0 40px;
    }

    .eyebrow {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0;
      margin-bottom: 12px;
    }

    h1 {
      color: var(--fg);
      font-size: 96px;
      line-height: 0.95;
      margin: 0 0 20px;
    }

    .lead {
      max-width: 640px;
      color: var(--fg-dim);
      font-size: 18px;
      line-height: 1.75;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: 1fr;
      border-top: 1px solid var(--fg);
    }

    .hero-stats div {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 16px;
      align-items: baseline;
      border-bottom: 1px solid var(--border);
      min-height: 58px;
      padding: 14px 0;
    }

    .hero-stats dt {
      color: var(--fg-mute);
      font-size: 13px;
      font-weight: 600;
    }

    .hero-stats dd {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 16px;
      font-weight: 600;
      line-height: 1.45;
      min-width: 0;
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      gap: 24px;
      align-items: end;
      margin-bottom: 20px;
    }

    .section-head h2 {
      color: var(--fg);
      font-size: 28px;
      line-height: 1.25;
    }

    .section-head p:last-child {
      max-width: 380px;
      color: var(--fg-mute);
      font-size: 14px;
      line-height: 1.65;
      text-align: right;
    }

    .signal-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      border-top: 1px solid var(--fg);
      border-left: 1px solid var(--border);
    }

    .signal-grid div {
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      min-height: 174px;
      padding: 18px;
    }

    .signal-grid span,
    .card-top,
    .archive-list time,
    .archive-list small {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      min-width: 0;
    }

    .signal-grid strong {
      color: var(--fg);
      display: block;
      font-family: var(--mono);
      font-size: 34px;
      line-height: 1;
      margin: 34px 0 12px;
    }

    .signal-grid p {
      color: var(--fg-dim);
      font-size: 14px;
      line-height: 1.65;
    }

    .latest-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }

    .issue-card {
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg);
      color: var(--fg);
      min-height: 260px;
      padding: 18px;
      text-decoration: none;
    }

    .issue-card.primary {
      background: var(--fg);
      border-color: var(--fg);
      color: var(--bg);
    }

    .issue-card:hover {
      color: var(--fg);
      border-color: var(--fg);
      text-decoration: none;
    }

    .issue-card.primary:hover {
      color: var(--bg);
    }

    .card-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 42px;
    }

    .issue-card.primary .card-top,
    .issue-card.primary p {
      color: rgba(255, 255, 255, 0.7);
    }

    .issue-card h3 {
      color: inherit;
      font-size: 18px;
      line-height: 1.38;
      margin-bottom: 12px;
      word-break: keep-all;
      overflow-wrap: anywhere;
    }

    .issue-card p {
      color: var(--fg-dim);
      font-size: 14px;
      line-height: 1.65;
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 18px;
    }

    .badge-row span {
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--fg-dim);
      font-family: var(--mono);
      font-size: 11px;
      line-height: 1;
      padding: 6px 9px;
    }

    .issue-card.primary .badge-row span {
      border-color: rgba(255, 255, 255, 0.3);
      color: rgba(255, 255, 255, 0.82);
    }

    .severity-high,
    .recurrence-high {
      color: var(--danger) !important;
    }

    .severity-medium,
    .recurrence-medium {
      color: var(--warn) !important;
    }

    .archive-list {
      display: grid;
      gap: 16px;
      min-width: 0;
    }

    .month-block {
      border-top: 1px solid var(--fg);
      min-width: 0;
      padding-top: 16px;
    }

    .month-block header {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      align-items: baseline;
      margin-bottom: 8px;
    }

    .month-block h3 {
      color: var(--fg);
      font-size: 22px;
      line-height: 1.25;
    }

    .month-block header span {
      color: var(--fg-mute);
      font-size: 13px;
      font-weight: 600;
    }

    .month-block ol {
      list-style: none;
      border-top: 1px solid var(--border);
      min-width: 0;
    }

    .month-block li {
      border-bottom: 1px solid var(--border);
      min-width: 0;
    }

    .month-block a {
      display: grid;
      grid-template-columns: 112px minmax(0, 1fr) 120px;
      gap: 16px;
      align-items: baseline;
      min-height: 54px;
      padding: 14px 0;
      color: var(--fg);
      min-width: 0;
      text-decoration: none;
    }

    .month-block a:hover span {
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.2em;
    }

    .month-block a > span {
      color: var(--fg);
      font-size: 15px;
      line-height: 1.5;
      min-width: 0;
      overflow-wrap: anywhere;
      word-break: keep-all;
    }

    .month-block small {
      text-align: right;
      overflow-wrap: anywhere;
      white-space: normal;
    }

    .issues-footer {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      border-top: 1px solid var(--border);
      padding-top: 20px;
    }

    .issues-footer p,
    .issues-footer a {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
    }

    @media (max-width: 900px) {
      .issues-hero {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 72px;
      }

      .signal-grid,
      .latest-grid {
        grid-template-columns: 1fr;
      }

      .issue-card {
        min-height: auto;
      }
    }

    @media (max-width: 640px) {
      .issues-page {
        gap: 52px;
      }

      h1 {
        font-size: 56px;
      }

      .lead {
        font-size: 16px;
      }

      .section-head,
      .archive-head {
        display: block;
      }

      .section-head h2 {
        font-size: 24px;
      }

      .section-head p:last-child {
        margin-top: 8px;
        text-align: left;
      }

      .month-block a {
        grid-template-columns: 1fr;
        gap: 4px;
      }

      .month-block small {
        text-align: left;
      }

      .issues-footer {
        flex-direction: column;
      }
    }
  </style>
</Layout>

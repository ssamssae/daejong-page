---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import Layout from '../layouts/Layout.astro';

type KnowhowEntry = {
  file: string;
  date: string;
  slug: string;
  title: string;
  category?: string;
  tags?: string[];
  summary?: string;
  first_discovered?: string;
  rediscovered?: string;
};

const knowhowIndex = JSON.parse(
  readFileSync(join(process.cwd(), 'public/knowhow/index.json'), 'utf-8'),
) as { entries?: KnowhowEntry[] };

const entries = (knowhowIndex.entries ?? [])
  .slice()
  .sort((a, b) => b.date.localeCompare(a.date) || a.title.localeCompare(b.title, 'ko'));

const categories = Array.from(
  entries.reduce((counts, entry) => {
    const category = entry.category?.trim();
    if (category) counts.set(category, (counts.get(category) ?? 0) + 1);
    return counts;
  }, new Map<string, number>()),
)
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'ko'));

const dates = entries.map((entry) => entry.date).filter(Boolean).sort();
const latestDate = dates.at(-1) ?? '';
const earliestDate = dates[0] ?? '';
const featuredEntries = entries.slice(0, 3);
const topCategories = categories.slice(0, 7);

const dateLabel = (value?: string) => (value ? value.replaceAll('-', '.') : '—');
const sourceFile = (entry: KnowhowEntry) => entry.file?.trim() || entry.slug + '.md';
const githubHref = (entry: KnowhowEntry) =>
  'https://github.com/ssamssae/daejong-page/blob/main/public/knowhow/' +
  encodeURIComponent(sourceFile(entry));

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://work.kangdaejong.com/#person',
      name: '강대종',
      jobTitle: 'Solo founder / Vibe coder',
      url: 'https://work.kangdaejong.com/',
      sameAs: ['https://github.com/ssamssae'],
    },
    {
      '@type': 'CollectionPage',
      '@id': 'https://work.kangdaejong.com/knowhow.html#page',
      url: 'https://work.kangdaejong.com/knowhow.html',
      name: '노하우 — 강대종',
      description: '다음 작업에서 다시 꺼내 쓰기 위한 재사용 노하우 아카이브.',
      inLanguage: 'ko',
      author: { '@id': 'https://work.kangdaejong.com/#person' },
      mainEntity: {
        '@type': 'ItemList',
        numberOfItems: entries.length,
        itemListElement: entries.map((entry, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: entry.title,
          url: githubHref(entry),
        })),
      },
    },
  ],
};
---

<Layout
  title="노하우 — 마이너스베타스튜디오"
  description="1인 개발과 AI 협업에서 발견한 우회 방법, 트릭, 운영 패턴을 다시 꺼내 쓰기 좋게 정리한 노하우 아카이브."
>
  <Fragment slot="head">
    <meta property="og:title" content="노하우 — 마이너스베타스튜디오" />
    <meta
      property="og:description"
      content="한 번 해결한 문제를 다음 작업의 시작점으로 바꾸는 재사용 노하우 아카이브."
    />
    <meta property="og:image" content="https://work.kangdaejong.com/og-default.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://work.kangdaejong.com/knowhow.html" />
    <meta property="og:site_name" content="강대종 작업장" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="노하우 — 마이너스베타스튜디오" />
    <meta
      name="twitter:description"
      content="한 번 해결한 문제를 다음 작업의 시작점으로 바꾸는 재사용 노하우 아카이브."
    />
    <meta name="twitter:image" content="https://work.kangdaejong.com/og-default.png" />
    <link rel="canonical" href="https://work.kangdaejong.com/knowhow.html" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <article class="knowhow-page">
    <header class="knowhow-hero" aria-labelledby="page-title">
      <div class="hero-copy">
        <p class="eyebrow">REUSABLE FIELD NOTES</p>
        <h1 id="page-title">노하우</h1>
        <p class="lead">
          한 번 해결한 문제를 다음 작업의 시작점으로 바꿉니다. 사건 자체보다 다시 쓸 수 있는
          판단 기준, 우회 방법, 운영 패턴만 골라 기록합니다.
        </p>
      </div>

      <dl class="hero-stats" aria-label="노하우 아카이브 요약">
        <div>
          <dt>기록</dt>
          <dd>{entries.length}<small>notes</small></dd>
        </div>
        <div>
          <dt>분류</dt>
          <dd>{categories.length}<small>topics</small></dd>
        </div>
        <div>
          <dt>범위</dt>
          <dd class="date-range">{dateLabel(earliestDate)} — {dateLabel(latestDate)}</dd>
        </div>
      </dl>
    </header>

    <aside class="update-note" aria-label="최근 변경">
      <span class="update-label">RECENT UPDATE</span>
      <p>
        <time datetime="2026-07-07">2026.07.07</time>
        <span>노하우 3편 추가</span>
        <span>durable 스케줄러 · detached HEAD push 실패 · 이중디스패치 claim 게이트</span>
      </p>
    </aside>

    <section class="featured-section" data-featured-section aria-labelledby="featured-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">LATEST NOTES</p>
          <h2 id="featured-title">최근에 꺼내 쓴 노하우</h2>
        </div>
        <p>가장 최근에 일반화한 세 가지 패턴입니다. 전체 본문은 GitHub에서 이어집니다.</p>
      </div>

      <div class="featured-grid">
        {
          featuredEntries.map((entry, index) => {
            const tags = entry.tags ?? [];
            return (
              <a
                class={index === 0 ? 'featured-card featured-primary' : 'featured-card'}
                href={githubHref(entry)}
                target="_blank"
                rel="noopener"
                aria-label={entry.title + ' 원문을 GitHub에서 열기'}
              >
                <span class="card-index">{String(index + 1).padStart(2, '0')}</span>
                <span class="featured-meta">
                  <time datetime={entry.date}>{dateLabel(entry.date)}</time>
                  <span>{entry.category || '미분류'}</span>
                </span>
                <h3>{entry.title}</h3>
                {entry.summary && <p>{entry.summary}</p>}
                <span class="featured-foot">
                  <span>{tags.slice(0, index === 0 ? 3 : 2).join(' · ')}</span>
                  <span aria-hidden="true">↗</span>
                </span>
              </a>
            );
          })
        }
      </div>
    </section>

    <section class="archive-section" aria-labelledby="archive-title">
      <div class="section-head archive-head">
        <div>
          <p class="eyebrow">KNOWLEDGE INDEX</p>
          <h2 id="archive-title">전체 아카이브</h2>
        </div>
        <p>제목, 요약, 태그를 함께 검색하거나 카테고리로 범위를 좁힐 수 있습니다.</p>
      </div>

      <form class="filter-panel" data-filter-form role="search">
        <div class="filter-field search-field">
          <label for="knowhow-search">키워드 검색</label>
          <div class="input-shell">
            <span aria-hidden="true">⌕</span>
            <input
              id="knowhow-search"
              data-search-input
              type="search"
              inputmode="search"
              autocomplete="off"
              placeholder="예: launchd, Flutter, 검증"
              aria-describedby="filter-status"
            />
            <kbd aria-hidden="true">/</kbd>
          </div>
        </div>

        <div class="filter-field category-field">
          <label for="knowhow-category">카테고리</label>
          <select id="knowhow-category" data-category-select aria-describedby="filter-status">
            <option value="">전체 카테고리</option>
            {categories.map((category) => (
              <option value={category.name}>{category.name} · {category.count}</option>
            ))}
          </select>
        </div>

        <button class="reset-button" type="reset">초기화</button>
      </form>

      <div class="category-rail" aria-label="주요 카테고리 바로가기">
        <button class="category-chip is-active" type="button" data-category-chip="" aria-pressed="true">
          전체 <span>{entries.length}</span>
        </button>
        {
          topCategories.map((category) => (
            <button
              class="category-chip"
              type="button"
              data-category-chip={category.name}
              aria-pressed="false"
            >
              {category.name} <span>{category.count}</span>
            </button>
          ))
        }
      </div>

      <div class="archive-toolbar">
        <p id="filter-status" data-filter-status aria-live="polite">전체 {entries.length}건</p>
        <span>최신순</span>
      </div>

      <div class="entry-grid" data-entry-grid>
        {
          entries.map((entry, index) => {
            const tags = entry.tags ?? [];
            const searchText = [
              entry.title,
              entry.summary,
              entry.category,
              ...tags,
            ]
              .filter(Boolean)
              .join(' ')
              .toLocaleLowerCase('ko-KR');
            const discovered = entry.first_discovered || entry.date;
            const rediscovered =
              entry.rediscovered && entry.rediscovered !== discovered ? entry.rediscovered : '';

            return (
              <article
                class="entry-card"
                data-knowhow-entry
                data-category={entry.category || ''}
                data-search={searchText}
              >
                <a
                  href={githubHref(entry)}
                  target="_blank"
                  rel="noopener"
                  aria-label={entry.title + ' 원문을 GitHub에서 열기'}
                >
                  <span class="entry-topline">
                    <span>{String(index + 1).padStart(2, '0')}</span>
                    <span>{entry.category || '미분류'}</span>
                  </span>
                  <h3>{entry.title}</h3>
                  {entry.summary && <p class="entry-summary">{entry.summary}</p>}
                  <span class="entry-meta">
                    <span>첫 발견 {dateLabel(discovered)}</span>
                    {rediscovered && <span>재발견 {dateLabel(rediscovered)}</span>}
                  </span>
                  {tags.length > 0 && (
                    <span class="entry-tags" aria-label="태그">
                      {tags.slice(0, 4).map((tag) => <span>#{tag}</span>)}
                      {tags.length > 4 && <span>+{tags.length - 4}</span>}
                    </span>
                  )}
                  <span class="entry-link">
                    원문 보기
                    <span aria-hidden="true">↗</span>
                  </span>
                </a>
              </article>
            );
          })
        }
      </div>

      <div class="empty-state" data-empty-state hidden>
        <strong>일치하는 노하우가 없습니다.</strong>
        <p>검색어를 줄이거나 카테고리를 전체로 바꿔보세요.</p>
        <button type="button" data-empty-reset>필터 초기화</button>
      </div>
    </section>

    <footer class="knowhow-footer">
      <p>마지막 갱신 {dateLabel(latestDate)} · 원문 저장소 기준</p>
      <a href="/system">system으로 돌아가기</a>
    </footer>
  </article>

  <script is:inline>
    (() => {
      const form = document.querySelector('[data-filter-form]');
      const searchInput = document.querySelector('[data-search-input]');
      const categorySelect = document.querySelector('[data-category-select]');
      const status = document.querySelector('[data-filter-status]');
      const cards = Array.from(document.querySelectorAll('[data-knowhow-entry]'));
      const chips = Array.from(document.querySelectorAll('[data-category-chip]'));
      const emptyState = document.querySelector('[data-empty-state]');
      const emptyReset = document.querySelector('[data-empty-reset]');
      const featuredSection = document.querySelector('[data-featured-section]');

      if (
        !(form instanceof HTMLFormElement) ||
        !(searchInput instanceof HTMLInputElement) ||
        !(categorySelect instanceof HTMLSelectElement) ||
        !(status instanceof HTMLElement)
      ) {
        return;
      }

      const normalize = (value) =>
        String(value || '').normalize('NFKC').toLocaleLowerCase('ko-KR').trim();

      const setChipState = (category) => {
        chips.forEach((chip) => {
          const isActive = (chip.getAttribute('data-category-chip') || '') === category;
          chip.classList.toggle('is-active', isActive);
          chip.setAttribute('aria-pressed', String(isActive));
        });
      };

      const updateUrl = (query, category) => {
        const params = new URLSearchParams(window.location.search);
        if (query) params.set('q', query);
        else params.delete('q');
        if (category) params.set('category', category);
        else params.delete('category');
        const next = params.toString();
        window.history.replaceState(null, '', window.location.pathname + (next ? '?' + next : ''));
      };

      const applyFilters = (syncUrl = true) => {
        const query = normalize(searchInput.value);
        const category = categorySelect.value;
        const tokens = query.split(/\s+/).filter(Boolean);
        let visible = 0;

        cards.forEach((card) => {
          const haystack = normalize(card.getAttribute('data-search'));
          const cardCategory = card.getAttribute('data-category') || '';
          const matchesQuery = tokens.every((token) => haystack.includes(token));
          const matchesCategory = !category || cardCategory === category;
          const matches = matchesQuery && matchesCategory;
          card.hidden = !matches;
          if (matches) visible += 1;
        });

        const labelBits = [];
        if (category) labelBits.push(category);
        if (query) labelBits.push('“' + searchInput.value.trim() + '”');
        status.textContent = (labelBits.length ? labelBits.join(' · ') : '전체') + ' ' + visible + '건';
        if (emptyState instanceof HTMLElement) emptyState.hidden = visible !== 0;
        if (featuredSection instanceof HTMLElement) featuredSection.hidden = Boolean(query || category);
        setChipState(category);
        if (syncUrl) updateUrl(searchInput.value.trim(), category);
      };

      const resetFilters = (focusSearch = false) => {
        searchInput.value = '';
        categorySelect.value = '';
        applyFilters();
        if (focusSearch) searchInput.focus();
      };

      const syncFromUrl = () => {
        const params = new URLSearchParams(window.location.search);
        const category = params.get('category') || '';
        searchInput.value = params.get('q') || '';
        categorySelect.value = Array.from(categorySelect.options).some(
          (option) => option.value === category,
        )
          ? category
          : '';
        applyFilters(false);
      };

      searchInput.addEventListener('input', () => applyFilters());
      categorySelect.addEventListener('change', () => applyFilters());
      form.addEventListener('submit', (event) => event.preventDefault());
      form.addEventListener('reset', (event) => {
        event.preventDefault();
        resetFilters(true);
      });

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          categorySelect.value = chip.getAttribute('data-category-chip') || '';
          applyFilters();
          document.querySelector('[data-entry-grid]')?.scrollIntoView({
            behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
            block: 'start',
          });
        });
      });

      emptyReset?.addEventListener('click', () => resetFilters(true));
      window.addEventListener('popstate', syncFromUrl);
      document.addEventListener('keydown', (event) => {
        if (
          event.key === '/' &&
          !event.metaKey &&
          !event.ctrlKey &&
          !event.altKey &&
          !(event.target instanceof HTMLInputElement) &&
          !(event.target instanceof HTMLTextAreaElement) &&
          !(event.target instanceof HTMLSelectElement)
        ) {
          event.preventDefault();
          searchInput.focus();
        }
        if (event.key === 'Escape' && document.activeElement === searchInput && searchInput.value) {
          searchInput.value = '';
          applyFilters();
        }
      });

      syncFromUrl();
    })();
  </script>

  <style>
    .knowhow-page {
      --knowhow-accent: var(--accent);
      display: flex;
      min-width: 0;
      flex-direction: column;
      gap: 72px;
    }

    .knowhow-page > * {
      min-width: 0;
    }

    .knowhow-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      gap: 48px;
      align-items: end;
      border-bottom: 1px solid var(--border);
      padding: 18px 0 40px;
    }

    .eyebrow,
    .card-index,
    .featured-meta,
    .featured-foot,
    .entry-topline,
    .entry-meta,
    .entry-tags,
    .entry-link,
    .archive-toolbar,
    .update-label,
    .filter-field label,
    .category-chip,
    .knowhow-footer {
      font-family: var(--mono);
    }

    .eyebrow {
      margin-bottom: 12px;
      color: var(--fg-mute);
      font-size: 12px;
      font-weight: 600;
    }

    h1 {
      margin: 0 0 22px;
      color: var(--fg);
      font-size: clamp(64px, 9vw, 108px);
      line-height: 0.9;
      letter-spacing: -0.055em;
    }

    .lead {
      max-width: 660px;
      color: var(--fg-dim);
      font-size: 18px;
      line-height: 1.75;
      word-break: keep-all;
    }

    .hero-stats {
      display: grid;
      border-top: 1px solid var(--fg);
    }

    .hero-stats > div {
      display: grid;
      grid-template-columns: 80px minmax(0, 1fr);
      gap: 16px;
      align-items: baseline;
      min-height: 62px;
      border-bottom: 1px solid var(--border);
      padding: 15px 0;
    }

    .hero-stats dt {
      color: var(--fg-mute);
      font-size: 13px;
      font-weight: 600;
    }

    .hero-stats dd {
      display: flex;
      min-width: 0;
      align-items: baseline;
      gap: 8px;
      color: var(--fg);
      font-family: var(--mono);
      font-size: 23px;
      font-weight: 600;
      line-height: 1.35;
    }

    .hero-stats dd small {
      color: var(--fg-mute);
      font-size: 11px;
      font-weight: 500;
    }

    .hero-stats .date-range {
      font-size: 14px;
      letter-spacing: -0.025em;
      white-space: nowrap;
    }

    .update-note {
      display: grid;
      grid-template-columns: 148px minmax(0, 1fr);
      gap: 24px;
      align-items: baseline;
      margin-top: -44px;
      border-bottom: 1px solid var(--border);
      padding: 0 0 24px;
    }

    .update-label {
      color: var(--knowhow-accent);
      font-size: 11px;
      font-weight: 700;
    }

    .update-note p {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 18px;
      color: var(--fg-dim);
      font-size: 13px;
      line-height: 1.6;
    }

    .update-note time {
      color: var(--fg);
      font-family: var(--mono);
      font-weight: 600;
    }

    .section-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 390px);
      gap: 32px;
      align-items: end;
      margin-bottom: 24px;
    }

    .section-head h2 {
      color: var(--fg);
      font-size: 34px;
      line-height: 1.2;
      letter-spacing: -0.025em;
      word-break: keep-all;
    }

    .section-head > p {
      color: var(--fg-mute);
      font-size: 14px;
      line-height: 1.7;
      text-align: right;
      word-break: keep-all;
    }

    .featured-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
      grid-template-rows: repeat(2, minmax(190px, auto));
      border-top: 1px solid var(--fg);
      border-left: 1px solid var(--border);
    }

    .featured-card {
      position: relative;
      display: flex;
      min-width: 0;
      flex-direction: column;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      color: var(--fg);
      padding: 22px;
      text-decoration: none;
      transition: background 160ms ease, color 160ms ease;
    }

    .featured-card:hover {
      background: var(--bg-elev);
      color: var(--fg);
      text-decoration: none;
    }

    .featured-card:focus-visible,
    .entry-card > a:focus-visible,
    .category-chip:focus-visible,
    .reset-button:focus-visible,
    .empty-state button:focus-visible,
    .input-shell:focus-within,
    select:focus-visible {
      outline: 2px solid var(--knowhow-accent);
      outline-offset: 3px;
    }

    .featured-primary {
      grid-row: 1 / span 2;
      min-height: 430px;
      padding: 28px;
    }

    .card-index {
      position: absolute;
      top: 22px;
      right: 22px;
      color: var(--fg-mute);
      font-size: 12px;
      font-weight: 600;
    }

    .featured-primary .card-index {
      top: 28px;
      right: 28px;
    }

    .featured-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 14px;
      padding-right: 40px;
      color: var(--fg-mute);
      font-size: 11px;
      font-weight: 600;
    }

    .featured-meta span {
      color: var(--knowhow-accent);
    }

    .featured-card h3 {
      max-width: 580px;
      margin-top: 42px;
      color: var(--fg);
      font-size: 20px;
      line-height: 1.4;
      letter-spacing: -0.018em;
      word-break: keep-all;
    }

    .featured-primary h3 {
      margin-top: 72px;
      font-size: clamp(28px, 3.2vw, 40px);
      line-height: 1.22;
    }

    .featured-card p {
      display: -webkit-box;
      margin-top: 14px;
      overflow: hidden;
      color: var(--fg-dim);
      font-size: 13px;
      line-height: 1.65;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .featured-primary p {
      max-width: 620px;
      margin-top: 22px;
      font-size: 15px;
      line-height: 1.75;
      -webkit-line-clamp: 4;
    }

    .featured-foot {
      display: flex;
      justify-content: space-between;
      gap: 18px;

---
import Layout from '../layouts/Layout.astro';

const items = [
  {
    href: '/issues.html',
    kicker: 'POSTMORTEM',
    title: '이슈',
    desc: '발생했다 해결한 이슈와 혼선의 포스트모템. 증상, 원인, 조치, 예방을 남깁니다.',
    group: '운영 기록',
  },
  {
    href: '/dead-ends.html',
    kicker: 'DEAD ENDS',
    title: '막다른 길',
    desc: '제품이 되지 못했거나 구조적으로 막힌 시도들. 같은 벽을 다시 치지 않기 위한 기록입니다.',
    group: '운영 기록',
  },
  {
    href: '/timeline.html',
    kicker: 'TIMELINE',
    title: '개발 타임라인',
    desc: '앱 출시, 인프라 구축, 큰 결정과 학습 이정표를 시간순으로 훑는 기록입니다.',
    group: '운영 기록',
  },
  {
    href: '/ai-glossary.html',
    kicker: 'GLOSSARY',
    title: 'AI 용어집',
    desc: '영상과 작업 중 나온 AI·Claude·Anthropic 용어를 1인 개발자 맥락으로 정리합니다.',
    group: '지식 노트',
  },
  {
    href: '/vibecoding.html',
    kicker: 'METHOD',
    title: '바이브코딩',
    desc: 'Claude/Codex와 같이 코딩하면서 생긴 작업 방식, 스킬, 운영 습관의 변천사입니다.',
    group: '지식 노트',
  },
  {
    href: '/habits.html',
    kicker: 'HABITS',
    title: '습관',
    desc: '세션 운영, 완료 마킹, 보고, 시간 표기처럼 반복해서 지켜야 하는 작은 습관들입니다.',
    group: '지식 노트',
  },
  {
    href: '/vrl-benchmark.html',
    kicker: 'BENCHMARK',
    title: 'VRL 벤치마크',
    desc: '모델과 도구를 직접 비교한 실험성 메모입니다.',
    group: '실험',
  },
  {
    href: '/stock.html',
    kicker: 'STOCK',
    title: '주식',
    desc: '투자 관련 메모와 관찰 기록입니다.',
    group: '실험',
  },
  {
    href: '/sise.html',
    kicker: 'MARKET',
    title: '시세',
    desc: '시세 관련 실험과 데이터 관찰을 모아둡니다.',
    group: '실험',
  },
  {
    href: '/sorry/',
    kicker: 'LOG',
    title: '반성문',
    desc: '에이전트가 실수한 순간을 기록하고, 같은 실수를 줄이기 위한 흔적을 남깁니다.',
    group: '실험',
  },
];

const featured = [items[0], items[1], items[3]];
const groups = ['운영 기록', '지식 노트', '실험'].map((label) => ({
  label,
  items: items.filter((item) => item.group === label),
}));

const principles = [
  ['실패도 자산으로 남깁니다.', '접은 시도는 지우지 않고, 다음 작업에서 같은 비용을 다시 내지 않게 보관합니다.'],
  ['잡학은 연결될 때까지 둡니다.', '지금은 제품이 아니어도 용어, 습관, 실험은 다음 빌드의 재료가 됩니다.'],
  ['공개 가능한 것만 씁니다.', '실제 운영 세부와 민감한 정보는 제외하고, 배울 수 있는 구조만 남깁니다.'],
];
---
<Layout title="lab — 마이너스베타스튜디오" description="잡학, 실험, 포스트모템, 접은 시도를 모아둔 공개 실험실.">
  <div class="lab-index">
    <section class="lab-hero" aria-labelledby="page-title">
      <div class="hero-copy">
        <p class="eyebrow">LAB NOTEBOOK</p>
        <h1 id="page-title">lab</h1>
        <p class="lead">
          제품으로 바로 묶이지 않는 잡학, 실험, 포스트모템, 접은 시도를 모아둡니다.
          성공한 것보다 다시 같은 길을 밟지 않게 만드는 기록에 가깝습니다.
        </p>
      </div>
      <dl class="hero-stats" aria-label="lab 요약">
        <div>
          <dt>문서</dt>
          <dd>{items.length}</dd>
          <span>실험과 기록 링크</span>
        </div>
        <div>
          <dt>묶음</dt>
          <dd>{groups.length}</dd>
          <span>운영 기록 · 지식 노트 · 실험</span>
        </div>
        <div>
          <dt>원칙</dt>
          <dd>공개</dd>
          <span>내부 세부는 빼고 구조만 남깁니다.</span>
        </div>
      </dl>
    </section>

    <section class="featured-section" aria-labelledby="featured-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">START HERE</p>
          <h2 id="featured-title">먼저 볼 기록</h2>
        </div>
        <p>운영 사고, 접은 길, 용어 정리를 먼저 보면 이 lab이 왜 필요한지 빠르게 보입니다.</p>
      </div>

      <div class="featured-grid">
        {featured.map((item, index) => (
          <a class={index === 0 ? 'feature-card primary' : 'feature-card'} href={item.href}>
            <span class="card-topline">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <span>{item.kicker}</span>
            </span>
            <strong>{item.title}</strong>
            <span>{item.desc}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="archive-section" aria-labelledby="archive-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">INDEX</p>
          <h2 id="archive-title">전체 lab</h2>
        </div>
        <p>성격별로 나눠 필요한 기록으로 바로 들어갈 수 있게 정리했습니다.</p>
      </div>

      <div class="archive-list">
        {groups.map((group) => (
          <section class="group-block" aria-labelledby={`group-${group.label}`}>
            <header>
              <h3 id={`group-${group.label}`}>{group.label}</h3>
              <span>{group.items.length}개</span>
            </header>
            <ol>
              {group.items.map((item) => (
                <li>
                  <a href={item.href}>
                    <span>{item.kicker}</span>
                    <strong>{item.title}</strong>
                    <em>{item.desc}</em>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    </section>

    <section class="principle-section" aria-labelledby="principle-title">
      <div class="section-head compact">
        <div>
          <p class="eyebrow">WHY KEEP IT</p>
          <h2 id="principle-title">lab에 남기는 기준</h2>
        </div>
      </div>

      <dl class="principle-list">
        {principles.map(([term, desc]) => (
          <div>
            <dt>{term}</dt>
            <dd>{desc}</dd>
          </div>
        ))}
      </dl>
    </section>
  </div>

  <style>
    .lab-index {
      display: flex;
      flex-direction: column;
      gap: 64px;
    }

    .lab-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      gap: 40px;
      align-items: end;
      border-bottom: 1px solid var(--border);
      padding: 18px 0 40px;
    }

    .eyebrow {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0;
      margin-bottom: 12px;
    }

    h1 {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 96px;
      font-weight: 600;
      line-height: 0.95;
      margin: 0 0 20px;
    }

    .lead {
      max-width: 680px;
      color: var(--fg-dim);
      font-size: 18px;
      line-height: 1.75;
      word-break: keep-all;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: 1fr;
      border-top: 1px solid var(--fg);
    }

    .hero-stats div {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 8px 16px;
      align-items: baseline;
      min-height: 70px;
      border-bottom: 1px solid var(--border);
      padding: 14px 0;
    }

    .hero-stats dt {
      color: var(--fg-mute);
      font-size: 13px;
      font-weight: 600;
    }

    .hero-stats dd {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 32px;
      font-weight: 600;
      line-height: 1;
    }

    .hero-stats span {
      grid-column: 2;
      color: var(--fg-dim);
      font-size: 13px;
      line-height: 1.5;
    }

    .section-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 380px);
      gap: 32px;
      align-items: end;
      margin-bottom: 24px;
    }

    .section-head.compact {
      display: block;
      margin-bottom: 16px;
    }

    .section-head h2 {
      color: var(--fg);
      font-size: 34px;
      line-height: 1.2;
      word-break: keep-all;
    }

    .section-head > p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.65;
      word-break: keep-all;
    }

    .featured-grid {
      display: grid;
      grid-template-columns: 1.08fr 0.96fr 0.96fr;
      gap: 16px;
    }

    .feature-card {
      display: flex;
      min-height: 260px;
      flex-direction: column;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg);
      color: var(--fg);
      padding: 22px;
      text-decoration: none;
    }

    .feature-card:hover {
      background: var(--bg-elev);
      color: var(--fg);
      text-decoration: none;
    }

    .feature-card.primary {
      background: var(--fg);
      color: var(--bg);
    }

    .feature-card.primary .card-topline,
    .feature-card.primary > span:last-child {
      color: rgba(255, 255, 255, 0.72);
    }

    .card-topline {
      display: flex;
      flex-direction: column;
      gap: 52px;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 14px;
    }

    .feature-card strong {
      color: inherit;
      font-size: 24px;
      line-height: 1.22;
      margin-bottom: 12px;
      word-break: keep-all;
    }

    .feature-card > span:last-child {
      color: var(--fg-dim);
      font-size: 14px;
      line-height: 1.65;
      margin-top: auto;
      word-break: keep-all;
    }

    .archive-list {
      display: grid;
      gap: 28px;
    }

    .group-block {
      display: grid;
      grid-template-columns: 180px minmax(0, 1fr);
      gap: 24px;
      border-top: 1px solid var(--border);
      padding-top: 24px;
    }

    .group-block header {
      position: sticky;
      top: 96px;
      align-self: start;
    }

    .group-block h3 {
      color: var(--fg);
      font-size: 22px;
      line-height: 1.25;
      margin-bottom: 6px;
    }

    .group-block header span {
      color: var(--fg-mute);
      font-size: 13px;
    }

    .group-block ol {
      border-top: 1px solid var(--border-soft);
      list-style: none;
    }

    .group-block li {
      border-bottom: 1px solid var(--border-soft);
    }

    .group-block a {
      display: grid;
      grid-template-columns: 132px minmax(160px, 220px) minmax(0, 1fr);
      gap: 20px;
      align-items: baseline;
      min-height: 66px;
      color: var(--fg);
      padding: 16px 0;
      text-decoration: none;
    }

    .group-block a:hover {
      background: var(--bg-elev);
      color: var(--fg);
      text-decoration: none;
    }

    .group-block a span {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .group-block a strong {
      color: var(--fg);
      font-size: 17px;
      line-height: 1.32;
      word-break: keep-all;
    }

    .group-block a em {
      color: var(--fg-dim);
      font-size: 14px;
      font-style: normal;
      line-height: 1.6;
      word-break: keep-all;
    }

    .principle-list {
      display: grid;
      border-top: 1px solid var(--border);
    }

    .principle-list div {
      display: grid;
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 24px;
      align-items: baseline;
      border-bottom: 1px solid var(--border);
      padding: 20px 0;
    }

    .principle-list dt {
      color: var(--fg);
      font-size: 18px;
      font-weight: 700;
      line-height: 1.3;
    }

    .principle-list dd {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.65;
      word-break: keep-all;
    }

    @media (max-width: 920px) {
      .lab-hero,
      .section-head,
      .featured-grid,
      .group-block,
      .group-block a,
      .principle-list div {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 64px;
      }

      .lead {
        font-size: 16px;
      }

      .hero-stats {
        max-width: 520px;
      }

      .group-block header {
        position: static;
      }

      .group-block a {
        gap: 6px;
      }
    }

    @media (max-width: 640px) {
      .lab-index {
        gap: 56px;
      }

      .lab-hero {
        gap: 34px;
        padding-top: 8px;
      }

      h1 {
        font-size: 56px;
      }

      .hero-stats div {
        grid-template-columns: 1fr;
      }

      .hero-stats span {
        grid-column: auto;
      }

      .section-head h2 {
        font-size: 28px;
      }

      .feature-card {
        min-height: 220px;
        padding: 20px;
      }

      .card-topline {
        gap: 36px;
      }
    }
  </style>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import policyData from '../data/fleet-policy.json';

// 살아있는 정책 거울 — SoT 는 정책을 구현한 코드의 @POLICY 헤더.
// 이 JSON 은 claude-automations/scripts/gen-policy-registry.py 가 떨군 공개용 슬림본
// (정책명·현재동작·변경일만, 내부 경로·task-id 제거).
const policies = policyData.policies;
const lastUpdated = policies.reduce((m, p) => (p.changed > m ? p.changed : m), '');
---
<Layout title="fleet 정책 — 마이너스베타스튜디오" description="물리 5대 · 논리 10노드(Claude 5 + Codex 5)가 지금 어떤 규칙으로 굴러가는지 — 코드가 SoT인 살아있는 정책 거울.">
  <section class="hero">
    <h1 class="logo">fleet 정책</h1>
    <p class="tagline">fleet policy · 살아있는 정책 거울</p>
    <p class="intro">물리 5대 · 논리 10노드(Claude 5 + Codex 5)가 지금 어떤 규칙으로 굴러가는지 — 코드가 SoT인 살아있는 거울. 최종 변경 {lastUpdated}.</p>
  </section>

  <table class="ptable">
    <thead><tr><th>정책</th><th>최근변경</th><th>현재 동작</th></tr></thead>
    <tbody>
      {policies.map((p) => (
        <tr>
          <td class="pid"><a href={`#${p.id}`}>{p.id}</a></td>
          <td class="pdate">{p.changed}</td>
          <td class="pcur">{p.current}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <div class="cards">
    {policies.map((p) => (
      <div class="card" id={p.id}>
        <div class="card-id">{p.id}</div>
        <div class="card-cur">{p.current}</div>
        <div class="card-date">최근 변경 {p.changed}</div>
      </div>
    ))}
  </div>

  <a class="back" href="/system">← system</a>

  <style>
    /* sorry/lab 톤 — 중앙 hero (테마색: 마젠타) */
    .hero { text-align: center; padding: 8px 0 40px; }
    .hero .logo { font-family: var(--mono); font-size: 48px; font-weight: 600; color: var(--magenta); line-height: 1.1; }
    .hero .tagline { font-family: var(--mono); font-size: 14px; color: var(--fg-dim); margin-top: 12px; }
    .hero .intro { color: var(--fg-dim); max-width: 520px; margin: 18px auto 0; font-size: 15px; line-height: 1.7; }

    .ptable { width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 36px; }
    .ptable th { text-align: left; font-family: var(--mono); color: var(--fg-dim); font-weight: 600; border-bottom: 1px solid var(--border); padding: 8px 10px; }
    .ptable td { border-bottom: 1px solid var(--border); padding: 10px; vertical-align: top; color: var(--fg-dim); }
    .pid a { font-family: var(--mono); color: var(--magenta); white-space: nowrap; }
    .pdate { font-family: var(--mono); white-space: nowrap; }
    .pcur { color: var(--fg); }
    @media (max-width: 640px) { .ptable { display: none; } }

    .cards { display: flex; flex-direction: column; gap: 10px; }
    .card { border: 1px solid var(--border); border-left: 3px solid var(--magenta); border-radius: 10px; padding: 16px 18px; background: var(--bg-elev); scroll-margin-top: 20px; }
    .card:target { border-color: var(--magenta); }
    .card-id { font-family: var(--mono); font-weight: 600; color: var(--magenta); }
    .card-cur { font-size: 14px; color: var(--fg); margin-top: 6px; line-height: 1.5; }
    .card-date { font-family: var(--mono); font-size: 12px; color: var(--fg-dim); margin-top: 8px; }

    .back { display: inline-block; margin-top: 28px; color: var(--fg-dim); text-decoration: none; font-family: var(--mono); font-size: 13px; }
    .back:hover { color: var(--magenta); }
  </style>
</Layout>

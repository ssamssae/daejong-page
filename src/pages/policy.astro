---
import Layout from '../layouts/Layout.astro';
import policyData from '../data/fleet-policy.json';

// 살아있는 정책 거울. SoT는 정책을 구현한 코드의 @POLICY 헤더다.
// 이 JSON은 claude-automations/scripts/gen-policy-registry.py가 공개 가능한 항목만 추린 슬림본이다.
const policies = [...policyData.policies]
  .map((policy, index) => ({ ...policy, index }))
  .sort((a, b) => {
    const byDate = b.changed.localeCompare(a.changed);
    return byDate || a.index - b.index;
  });

const lastUpdated = policies[0]?.changed ?? '—';
const changedDates = [...new Set(policies.map((policy) => policy.changed))];
const latestPolicies = policies.filter((policy) => policy.changed === lastUpdated);
const gatePolicyCount = policies.filter((policy) => /gate|deny|risk|r3|release|확인|금지|수동/.test(`${policy.id} ${policy.current}`)).length;

const stats = [
  { label: '등록 정책', value: String(policies.length), note: '공개 가능한 운영 규칙' },
  { label: '최신 변경', value: lastUpdated, note: `${latestPolicies.length}건 동시 갱신` },
  { label: '게이트 정책', value: String(gatePolicyCount), note: '자동화가 멈추는 지점' },
  { label: '변경일 묶음', value: String(changedDates.length), note: '정렬 기준 보존' },
];

const principles = [
  ['Code first', '정책 설명은 코드의 @POLICY 헤더에서 나온다. 페이지는 기록원이 아니라 공개 거울이다.'],
  ['Manual gate', '머지, 배포, 결제, 스토어, 물리 기기 같은 외부 영향은 사람이 닫는다.'],
  ['Evidence', '완료 판단은 보고 문장이 아니라 테스트, 빌드, PR, 로그 같은 실측 증거로 남긴다.'],
];
---
<Layout title="fleet 정책 — 마이너스베타스튜디오" description="마이너스베타스튜디오 5노드 AI 작업장이 따르는 운영 정책과 수동 게이트를 공개 가능한 범위로 정리한 정책 거울.">
  <div class="policy-page">
    <section class="policy-hero" aria-labelledby="page-title">
      <div class="hero-copy">
        <p class="eyebrow">FLEET POLICY</p>
        <h1 id="page-title">fleet 정책</h1>
        <p class="lead">
          5대 물리 노드와 10개 AI 레인이 어떤 규칙으로 움직이는지 공개 가능한 범위로 정리했습니다.
          내부 경로와 시크릿은 빼고, 자동화가 어디까지 가고 어디서 멈추는지만 남깁니다.
        </p>
      </div>

      <aside class="hero-panel" aria-label="정책 요약">
        <dl class="policy-stat-grid">
          {stats.map((stat) => (
            <div>
              <dt>{stat.label}</dt>
              <dd>{stat.value}</dd>
              <span>{stat.note}</span>
            </div>
          ))}
        </dl>
      </aside>
    </section>

    <section class="recent-section" aria-labelledby="recent-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">RECENT CHANGES</p>
          <h2 id="recent-title">최근 바뀐 정책부터 읽습니다.</h2>
        </div>
        <p>같은 날짜의 항목은 원본 등록 순서를 유지합니다. 오래된 항목도 숨기지 않고 아래 레지스트리에 그대로 둡니다.</p>
      </div>

      <div class="recent-rail">
        {policies.map((policy, index) => (
          <article class="recent-policy" id={policy.id}>
            <a href={`#registry-${policy.id}`} aria-label={`${policy.id} 상세로 이동`}>
              <span class="recent-index">{String(index + 1).padStart(2, '0')}</span>
              <strong>{policy.id}</strong>
              <time datetime={policy.changed}>{policy.changed}</time>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="registry-section" aria-labelledby="registry-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">REGISTRY</p>
          <h2 id="registry-title">정책 레지스트리</h2>
        </div>
        <p>각 행은 현재 동작만 설명합니다. 시행 이력, 내부 파일 경로, task 번호는 공개 페이지에 싣지 않습니다.</p>
      </div>

      <div class="policy-registry">
        {policies.map((policy, index) => (
          <article class="policy-row" id={`registry-${policy.id}`}>
            <div class="row-meta">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <time datetime={policy.changed}>{policy.changed}</time>
            </div>
            <div class="row-body">
              <h3>{policy.id}</h3>
              <p>{policy.current}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="principle-section" aria-labelledby="principle-title">
      <div class="section-head compact">
        <div>
          <p class="eyebrow">READING GUIDE</p>
          <h2 id="principle-title">이 페이지를 읽는 기준</h2>
        </div>
      </div>

      <dl class="principle-list">
        {principles.map(([term, desc]) => (
          <div>
            <dt>{term}</dt>
            <dd>{desc}</dd>
          </div>
        ))}
      </dl>
    </section>

    <a class="back" href="/system">← system</a>
  </div>

  <style>
    .policy-page {
      display: flex;
      flex-direction: column;
      gap: 64px;
      min-width: 0;
    }

    .policy-page > * {
      min-width: 0;
    }

    .policy-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 420px);
      gap: 40px;
      align-items: end;
      border-bottom: 1px solid var(--border);
      padding: 18px 0 42px;
    }

    .eyebrow {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0;
      margin-bottom: 12px;
    }

    h1 {
      color: var(--fg);
      font-size: 92px;
      line-height: 0.95;
      margin: 0 0 20px;
      word-break: keep-all;
    }

    .lead {
      max-width: 680px;
      color: var(--fg-dim);
      font-size: 18px;
      line-height: 1.75;
      word-break: keep-all;
    }

    .hero-panel {
      border-top: 1px solid var(--fg);
    }

    .policy-stat-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .policy-stat-grid div {
      min-height: 126px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 16px 16px 18px 0;
    }

    .policy-stat-grid div:nth-child(2n) {
      border-right: 0;
      padding-left: 16px;
    }

    .policy-stat-grid dt {
      color: var(--fg-mute);
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 20px;
    }

    .policy-stat-grid dd {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 22px;
      font-weight: 600;
      line-height: 1.1;
      overflow-wrap: anywhere;
    }

    .policy-stat-grid span {
      display: block;
      color: var(--fg-dim);
      font-size: 13px;
      line-height: 1.45;
      margin-top: 10px;
      word-break: keep-all;
    }

    .section-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 380px);
      gap: 32px;
      align-items: end;
      margin-bottom: 24px;
    }

    .section-head.compact {
      display: block;
      margin-bottom: 16px;
    }

    .section-head h2 {
      color: var(--fg);
      font-size: 34px;
      line-height: 1.2;
      word-break: keep-all;
    }

    .section-head > p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.65;
      word-break: keep-all;
    }

    .recent-rail {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
    }

    .recent-policy {
      min-width: 0;
    }

    .recent-policy a {
      display: flex;
      min-height: 164px;
      flex-direction: column;
      gap: 12px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      color: var(--fg);
      padding: 18px;
      text-decoration: none;
    }

    .recent-policy a:hover {
      background: var(--bg-elev);
      color: var(--fg);
      text-decoration: none;
    }

    .recent-index,
    .recent-policy time {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .recent-policy strong {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 16px;
      line-height: 1.35;
      margin-top: auto;
      overflow-wrap: anywhere;
    }

    .policy-registry {
      border-top: 1px solid var(--fg);
    }

    .policy-row {
      display: grid;
      grid-template-columns: 180px minmax(0, 1fr);
      gap: 28px;
      border-bottom: 1px solid var(--border);
      padding: 22px 0;
      scroll-margin-top: 92px;
    }

    .policy-row:target {
      background: var(--bg-elev);
      outline: 1px solid var(--border);
      outline-offset: 12px;
    }

    .row-meta {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .row-body h3 {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 22px;
      line-height: 1.3;
      margin-bottom: 10px;
      overflow-wrap: anywhere;
    }

    .row-body p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.75;
      max-width: 820px;
      word-break: keep-all;
    }

    .principle-list {
      display: grid;
      border-top: 1px solid var(--border);
    }

    .principle-list div {
      display: grid;
      grid-template-columns: 180px minmax(0, 1fr);
      gap: 24px;
      align-items: baseline;
      border-bottom: 1px solid var(--border);
      padding: 20px 0;
    }

    .principle-list dt {
      color: var(--fg);
      font-size: 18px;
      font-weight: 700;
      line-height: 1.3;
    }

    .principle-list dd {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.65;
      word-break: keep-all;
    }

    .back {
      align-self: flex-start;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 13px;
      text-decoration: none;
    }

    .back:hover {
      color: var(--fg);
      text-decoration: underline;
    }

    @media (max-width: 920px) {
      .policy-hero,
      .section-head,
      .policy-row,
      .principle-list div {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 64px;
      }

      .lead {
        font-size: 16px;
      }

      .hero-panel {
        max-width: 620px;
      }

      .recent-rail {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .policy-row {
        gap: 12px;
      }

      .row-meta {
        justify-content: flex-start;
      }
    }

    @media (max-width: 640px) {
      .policy-page {
        gap: 56px;
      }

      .policy-hero {
        gap: 34px;
        padding-top: 8px;
      }

      h1 {
        font-size: 48px;
        line-height: 1.04;
      }

      .policy-stat-grid,
      .recent-rail {
        grid-template-columns: 1fr;
      }

      .policy-stat-grid div,
      .policy-stat-grid div:nth-child(2n) {
        min-height: auto;
        border-right: 0;
        padding: 16px 0;
      }

      .policy-stat-grid dt {
        margin-bottom: 8px;
      }

      .section-head h2 {
        font-size: 28px;
      }

      .recent-policy a {
        min-height: 126px;
      }

      .row-body h3 {
        font-size: 19px;
      }
    }
  </style>
</Layout>

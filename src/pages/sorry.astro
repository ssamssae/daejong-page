---
import Layout from '../layouts/Layout.astro';
import sorryData from '../data/sorry.json';
import '../styles/lab.css';

// 사과 기록(반성문). stop-apology-detect 훅이 에이전트의 "죄송합니다" 발화를
// 자동 감지해 apology-entry-append.sh 로 이 데이터 파일(src/data/sorry.json)에 append 한다.
// 최신 엔트리가 배열 앞(prepend)이라 그대로 렌더한다.
const entries = (sorryData.entries ?? []);
---
<Layout title="반성문 — 마이너스베타스튜디오" description="에이전트가 아니키에게 사과한 기록. 자동 감지·기록.">
  <div class="lab-page" style="--page-accent: var(--danger)">
    <section class="lab-hero">
      <h1 class="logo">반성문</h1>
      <p class="tagline">sorry · 사과 기록</p>
      <p class="intro">에이전트가 일을 그르치거나 폐를 끼쳐 사과한 순간들의 자동 기록. 같은 실수를 반복하지 않으려는 흔적.</p>
    </section>

    {entries.length === 0 ? (
      <p class="lab-empty">아직 기록된 사과가 없습니다.</p>
    ) : (
      <div class="lab-list so-list">
        {entries.map((e) => (
          <article class="lab-card so-card">
            <div class="so-meta">
              <span class="so-date">{e.date}</span>
              {e.node && <span class="so-node">{e.node}</span>}
            </div>
            <p class="so-text">{e.full_text || e.summary || e.title}</p>
          </article>
        ))}
      </div>
    )}

    <a class="lab-back" href="/lab">← lab</a>
  </div>

  <style>
    .so-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 12px;
      margin-bottom: 10px;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      line-height: 1.5;
    }

    .so-node {
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 1px 8px;
      color: var(--fg-dim);
    }

    .so-text {
      max-width: 860px;
      color: var(--fg);
      font-size: 15px;
      line-height: 1.75;
      white-space: pre-wrap;
      word-break: keep-all;
      overflow-wrap: break-word;
    }
  </style>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import policyData from '../data/fleet-policy.json';

const policies = [...policyData.policies].sort((a, b) => b.changed.localeCompare(a.changed));
const latestPolicyDate = policies[0]?.changed ?? '—';

const stats = [
  { label: '물리 노드', value: '5' },
  { label: 'AI 레인', value: '10' },
  { label: '정책', value: policies.length },
];

const heroSummary = `5대 물리 노드 · 10개 AI 레인 · 정책 최신 ${latestPolicyDate}`;

const layers = [
  {
    step: '01',
    label: 'INPUT',
    title: '요청을 작업 단위로 바꿉니다.',
    desc: '폰에서 들어온 말은 곧바로 실행되지 않고, 목표·범위·검증이 있는 작업 계약으로 정리됩니다.',
  },
  {
    step: '02',
    label: 'ROUTING',
    title: '맞는 노드로 보냅니다.',
    desc: '플랫폼 의존 빌드, 무거운 테스트, 문서 정리처럼 성격이 다른 일을 역할별 노드로 나눕니다.',
  },
  {
    step: '03',
    label: 'EXECUTION',
    title: '브랜치에서 고치고 검증합니다.',
    desc: '작업 노드는 main을 직접 바꾸지 않고, 작은 변경과 실측 검증을 PR에 남깁니다.',
  },
  {
    step: '04',
    label: 'GATE',
    title: '외부 반영은 사람이 닫습니다.',
    desc: '머지, 배포, 스토어 제출, 물리 기기 제어처럼 되돌리기 어려운 일은 수동 게이트를 둡니다.',
  },
];

const modules = [
  {
    href: '/policy',
    kicker: 'POLICY',
    title: 'Fleet 정책',
    desc: '작업 노드가 어떤 규칙으로 움직이는지 공개 가능한 정책 거울로 정리합니다.',
  },
  {
    href: '/automations.html',
    kicker: 'AUTOMATION',
    title: '자동화',
    desc: '배차, 보고 보증, 스킬 감사, 출시 레일, 스마트홈 루틴을 한 장으로 봅니다.',
  },
  {
    href: '/stack.html',
    kicker: 'STACK',
    title: '기술 스택',
    desc: '5노드 작업장, Claude/Codex 레인, GPU, 모바일 입력면의 전체 구조입니다.',
  },
  {
    href: '/skills.html',
    kicker: 'SKILLS',
    title: 'AI 스킬',
    desc: '반복 업무를 Claude와 Codex에서 재사용하는 작업 루틴으로 묶습니다.',
  },
  {
    href: '/smart-home.html',
    kicker: 'SMART HOME',
    title: '스마트홈',
    desc: '자연어 가전 제어와 결정론 루틴을 안전 게이트 안에서 운용합니다.',
  },
  {
    href: '/knowhow.html',
    kicker: 'KNOWHOW',
    title: '노하우',
    desc: '1인 개발과 AI 협업을 실제 운영하면서 남긴 판단 기준과 시행착오입니다.',
  },
];

const safeguards = [
  ['손으로 닫는 지점', '머지·배포·결제·스토어 제출·물리기기 제어는 자동 경로 끝에서 멈춥니다.'],
  ['증거 우선', '완료 보고는 말이 아니라 빌드 출력, 테스트, 스크린샷, PR 링크로 닫습니다.'],
  ['공개 범위 제한', '사이트에는 내부 경로, 토큰, 실시간 제어 세부, 개인식별정보를 싣지 않습니다.'],
];
---
<Layout title="시스템 — 마이너스베타스튜디오" description="자동화 메시, Claude/Codex 운영 스택, 정책과 AI 스킬 시스템을 묶은 공개 시스템 허브.">
  <div class="system-page">
    <section class="system-hero" aria-labelledby="page-title">
      <div class="hero-copy">
        <p class="eyebrow">SYSTEM MAP</p>
        <h1 id="page-title">시스템</h1>
        <p class="lead">
          작업장 뒤에서 굴러가는 자동화 메시, Claude/Codex 운영 스택, 정책과 스킬을 한곳에 모았습니다.
          빠르게 만들되, 되돌리기 어려운 지점은 사람이 닫는 구조입니다.
        </p>
      </div>
      <div class="hero-side">
        <dl class="hero-stats" aria-label="시스템 요약">
          {stats.map((stat) => (
            <div>
              <dt>{stat.label}</dt>
              <dd>{stat.value}</dd>
            </div>
          ))}
        </dl>
        <p class="hero-summary">{heroSummary}</p>
      </div>
    </section>

    <section class="flow-section" aria-labelledby="flow-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">OPERATING FLOW</p>
          <h2 id="flow-title">요청은 네 단계로 닫힙니다.</h2>
        </div>
        <p>자동화는 빠르게 움직이지만, 공개 반영과 위험한 행동은 명시적인 수동 게이트를 통과합니다.</p>
      </div>

      <ol class="flow-list">
        {layers.map((layer) => (
          <li>
            <span class="step">{layer.step}</span>
            <span class="label">{layer.label}</span>
            <strong>{layer.title}</strong>
            <p>{layer.desc}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="module-section" aria-labelledby="module-title">
      <div class="section-head">
        <div>
          <p class="eyebrow">INDEX</p>
          <h2 id="module-title">관련 문서</h2>
        </div>
        <p>운영 정책, 자동화, 스택, 스킬, 스마트홈, 노하우를 각각 더 깊은 페이지로 나눴습니다.</p>
      </div>

      <div class="module-grid">
        {modules.map((item, index) => (
          <a class="module-card" href={item.href}>
            <span class="card-topline">
              <span>{String(index + 1).padStart(2, '0')}</span>
              <span>{item.kicker}</span>
            </span>
            <strong>{item.title}</strong>
            <span>{item.desc}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="safeguard-section" aria-labelledby="safeguard-title">
      <div class="section-head compact">
        <div>
          <p class="eyebrow">GUARDRAILS</p>
          <h2 id="safeguard-title">자동화가 넘어가지 않는 선</h2>
        </div>
      </div>

      <dl class="safeguard-list">
        {safeguards.map(([term, desc]) => (
          <div>
            <dt>{term}</dt>
            <dd>{desc}</dd>
          </div>
        ))}
      </dl>
    </section>
  </div>

  <style>
    .system-page {
      display: flex;
      flex-direction: column;
      gap: 64px;
    }

    .system-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      gap: 40px;
      align-items: end;
      border-bottom: 1px solid var(--border);
      padding: 18px 0 40px;
    }

    .eyebrow {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0;
      margin-bottom: 12px;
    }

    h1 {
      color: var(--fg);
      font-size: 96px;
      line-height: 0.95;
      margin: 0 0 20px;
    }

    .lead {
      max-width: 680px;
      color: var(--fg-dim);
      font-size: 18px;
      line-height: 1.75;
      word-break: keep-all;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: 1fr;
      border-top: 1px solid var(--fg);
    }

    .hero-stats div {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 16px;
      align-items: baseline;
      min-height: 58px;
      border-bottom: 1px solid var(--border);
      padding: 14px 0;
    }

    .hero-stats dt {
      color: var(--fg-mute);
      font-size: 13px;
      font-weight: 600;
    }

    .hero-stats dd {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 16px;
      font-weight: 600;
      line-height: 1.45;
    }

    .hero-summary {
      color: var(--fg-dim);
      font-size: 13px;
      line-height: 1.45;
      margin-top: 12px;
      white-space: nowrap;
    }

    .section-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 380px);
      gap: 32px;
      align-items: end;
      margin-bottom: 24px;
    }

    .section-head.compact {
      display: block;
      margin-bottom: 16px;
    }

    .section-head h2 {
      color: var(--fg);
      font-size: 34px;
      line-height: 1.2;
      word-break: keep-all;
    }

    .section-head > p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.65;
      word-break: keep-all;
    }

    .flow-list {
      border-top: 1px solid var(--border);
      list-style: none;
    }

    .flow-list li {
      display: grid;
      grid-template-columns: 52px 116px minmax(180px, 280px) minmax(0, 1fr);
      gap: 20px;
      align-items: baseline;
      border-bottom: 1px solid var(--border);
      min-height: 82px;
      padding: 22px 0;
    }

    .step,
    .label {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
    }

    .flow-list strong {
      color: var(--fg);
      font-size: 20px;
      line-height: 1.28;
      word-break: keep-all;
    }

    .flow-list p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.65;
      word-break: keep-all;
    }

    .module-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
    }

    .module-card {
      display: flex;
      min-height: 228px;
      flex-direction: column;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      color: var(--fg);
      padding: 22px;
      text-decoration: none;
    }

    .module-card:hover {
      background: var(--bg-elev);
      color: var(--fg);
      text-decoration: none;
    }

    .card-topline {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 42px;
    }

    .module-card strong {
      color: var(--fg);
      font-size: 24px;
      line-height: 1.22;
      margin-bottom: 12px;
    }

    .module-card > span:last-child {
      color: var(--fg-dim);
      font-size: 14px;
      line-height: 1.6;
      margin-top: auto;
      word-break: keep-all;
    }

    .safeguard-list {
      display: grid;
      border-top: 1px solid var(--border);
    }

    .safeguard-list div {
      display: grid;
      grid-template-columns: 180px minmax(0, 1fr);
      gap: 24px;
      align-items: baseline;
      border-bottom: 1px solid var(--border);
      padding: 20px 0;
    }

    .safeguard-list dt {
      color: var(--fg);
      font-size: 18px;
      font-weight: 700;
      line-height: 1.3;
    }

    .safeguard-list dd {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.65;
      word-break: keep-all;
    }

    @media (max-width: 920px) {
      .system-hero,
      .section-head,
      .flow-list li,
      .module-grid,
      .safeguard-list div {
        grid-template-columns: 1fr;
      }

      h1 {
        font-size: 64px;
      }

      .lead {
        font-size: 16px;
      }

      .hero-stats {
        max-width: 520px;
      }

      .flow-list li {
        gap: 8px;
      }
    }

    @media (max-width: 640px) {
      .system-page {
        gap: 56px;
      }

      .system-hero {
        gap: 34px;
        padding-top: 8px;
      }

      h1 {
        font-size: 56px;
      }

      .hero-stats div {
        grid-template-columns: 1fr;
      }

      .hero-summary {
        white-space: normal;
      }

      .section-head h2 {
        font-size: 28px;
      }

      .module-card {
        min-height: 208px;
        padding: 20px;
      }

      .card-topline {
        margin-bottom: 34px;
      }
    }
  </style>
</Layout>

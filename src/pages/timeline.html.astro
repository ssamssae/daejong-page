    ];

    function parseDate(s) {
      var parts = s.split('-');
      return new Date(+parts[0], +parts[1] - 1, +parts[2]);
    }
    function ymd(d) {
      var y = d.getFullYear();
      var m = String(d.getMonth() + 1).padStart(2, '0');
      var da = String(d.getDate()).padStart(2, '0');
      return y + '-' + m + '-' + da;
    }

    // Stats
    var startDate = parseDate('2026-04-11');
    var today = new Date(); today.setHours(0,0,0,0);
    var daysSinceStart = Math.floor((today - startDate) / 86400000) + 1;
    var activeDaysSet = {};
    events.forEach(function(e) { activeDaysSet[e.date] = true; });
    var activeDays = Object.keys(activeDaysSet).length;
    var totalEvents = events.length;
    var majorCount = events.filter(function(e) { return e.major; }).length;

    // longest streak of days with events
    var sortedDates = Object.keys(activeDaysSet).sort();
    var longestStreak = 0, currentStreak = 0, prev = null;
    sortedDates.forEach(function(ds) {
      var d = parseDate(ds);
      if (prev && (d - prev) === 86400000) currentStreak++;
      else currentStreak = 1;
      if (currentStreak > longestStreak) longestStreak = currentStreak;
      prev = d;
    });

    var statsEl = document.getElementById('stats');
    statsEl.innerHTML =
      '<div class="stat"><div class="stat-num" id="dayCount">0</div><div class="stat-label">개발 일수</div></div>' +
      '<div class="stat"><div class="stat-num">' + totalEvents + '</div><div class="stat-label">총 이벤트</div></div>' +
      '<div class="stat"><div class="stat-num">' + longestStreak + '</div><div class="stat-label">최장 연속일</div></div>' +
      '<div class="stat"><div class="stat-num">' + majorCount + '</div><div class="stat-label">주요 마일스톤</div></div>';

    // Animate day counter
    var dayEl = document.getElementById('dayCount');
    var c = 0;
    var iv = setInterval(function() {
      c++;
      dayEl.textContent = c;
      if (c >= daysSinceStart) clearInterval(iv);
    }, 60);

    // Heatmap — 12 weeks window ending on Saturday after today
    var endDate = new Date(today);
    // Move endDate to the Saturday of current week
    endDate.setDate(endDate.getDate() + (6 - endDate.getDay()));
    var totalWeeks = 12;
    var totalCells = totalWeeks * 7;
    var firstCellDate = new Date(endDate);
    firstCellDate.setDate(firstCellDate.getDate() - (totalCells - 1));

    // Align first cell to Sunday (should already be, since endDate is Saturday)
    var eventCountByDate = {};
    events.forEach(function(e) {
      eventCountByDate[e.date] = (eventCountByDate[e.date] || 0) + 1;
    });

    var daysEl = document.getElementById('heatmapDays');
    var dayLabels = ['', 'Mon', '', 'Wed', '', 'Fri', ''];
    daysEl.innerHTML = dayLabels.map(function(d) { return '<div class="heatmap-day-label">' + d + '</div>'; }).join('');

    var gridEl = document.getElementById('heatmapGrid');
    var monthsEl = document.getElementById('heatmapMonths');
    var gridHtml = '';
    var monthsHtml = '';
    var lastMonthShown = -1;
    for (var w = 0; w < totalWeeks; w++) {
      var weekStartDate = new Date(firstCellDate);
      weekStartDate.setDate(firstCellDate.getDate() + w * 7);
      var m = weekStartDate.getMonth();
      if (m !== lastMonthShown) {
        monthsHtml += '<div style="width:' + (12 + 3) + 'px;flex-shrink:0">' + (m + 1) + '월</div>';
        lastMonthShown = m;
      } else {
        monthsHtml += '<div style="width:' + (12 + 3) + 'px;flex-shrink:0"></div>';
      }
      for (var d = 0; d < 7; d++) {
        var cellDate = new Date(firstCellDate);
        cellDate.setDate(firstCellDate.getDate() + w * 7 + d);
        var key = ymd(cellDate);
        var count = eventCountByDate[key] || 0;
        var isFuture = cellDate > today;
        var isBeforeStart = cellDate < startDate;
        var lvClass = '';
        if (!isFuture && !isBeforeStart) {
          if (count >= 4) lvClass = 'lv4';
          else if (count >= 3) lvClass = 'lv3';
          else if (count >= 2) lvClass = 'lv2';
          else if (count >= 1) lvClass = 'lv1';
        }
        var titleAttr = key + (count > 0 ? ' · ' + count + '개 이벤트' : '');
        gridHtml += '<div class="hm-cell ' + lvClass + '" title="' + titleAttr + '" style="grid-row:' + (d + 1) + ';grid-column:' + (w + 1) + '"></div>';
      }
    }
    gridEl.innerHTML = gridHtml;
    monthsEl.innerHTML = monthsHtml;

    // Milestones
    var msEl = document.getElementById('milestones');
    var majors = events.filter(function(e) { return e.major; });
    msEl.innerHTML = majors.map(function(e) {
      return '<div class="ms-card">' +
        '<div class="ms-num">' + e.major + '</div>' +
        '<div class="ms-date">' + e.date.replace(/-/g, '.') + '</div>' +
        '<div class="ms-title">' + e.title + '</div>' +
      '</div>';
    }).join('');

    // Events list
    var evEl = document.getElementById('events');
    var sorted = events.slice().sort(function(a, b) {
      return a.date === b.date ? 0 : (a.date < b.date ? 1 : -1);
    });
    evEl.innerHTML = sorted.map(function(e) {
      var tagsHtml = e.tags.map(function(t) {
        return '<span class="tag ' + t[0] + '">' + t[1] + '</span>';
      }).join('');
      return '<div class="event-row ' + (e.major ? 'major' : '') + '">' +
        '<div class="er-date">' + e.date.replace(/-/g, '.') + '</div>' +
        '<div class="er-title"><strong>' + e.title + '</strong><span>' + e.desc + '</span></div>' +
        '<div class="er-tags">' + tagsHtml + '</div>' +
      '</div>';
    }).join('');
  </script>

---
import Layout from '../layouts/Layout.astro';

const stats = [
  { label: '활성 스킬', value: '39' },
  { label: '물리 기기', value: '4' },
  { label: '논리 노드', value: '8' },
  { label: '제작 기간', value: '약 7주' },
];

const timeline = [
  {
    period: '2026.04.27 이전',
    stage: '01',
    title: '첫 슬래시 커맨드',
    summary:
      'todo, worklog, done, goodnight 같은 반복 기록을 파일에 남기는 단계에서 시작했다. 아직은 단일 Mac 세션 안에서 돌아가는 작은 자동화였다.',
    tags: ['todo', 'worklog', 'done', 'goodnight'],
  },
  {
    period: '2026.04.29 - 05.04',
    stage: '02',
    title: 'Mac + WSL 2-way handoff',
    summary:
      'WSL을 두 번째 작업자로 붙이고 본진에서 지시, WSL에서 실행, 다시 본진으로 결과를 회수하는 양방향 운반체를 만들었다.',
    tags: ['parallel-cycle', 'wsl-flutter-test', 'submit-app'],
  },
  {
    period: '2026.05.05 - 05.07',
    stage: '03',
    title: '에이전트 메시',
    summary:
      'PLAN, EXECUTE, JUDGE, REPORT 흐름이 잡히면서 작업 분해와 검증을 에이전트 협력 구조로 넘기기 시작했다.',
    tags: ['loop-run', 'trio-vote', 'newsletter-publish'],
  },
  {
    period: '2026.05.08 - 05.09',
    stage: '04',
    title: 'Codex 합류와 스킬 다이어트',
    summary:
      'Mac mini가 세 번째 노드로 들어오고, 중복 스킬은 device-run 같은 공통 명령으로 합쳐졌다. 늘리는 것보다 줄이는 기준이 생겼다.',
    tags: ['device-run', 'night-runner', 'merge-janitor'],
  },
  {
    period: '2026.05.10 - 05.11',
    stage: '05',
    title: '5노드 메시',
    summary:
      '데스크탑 3060Ti와 노트북3060을 붙여 물리 5대 체제로 확장했다. GPU 실험, 모바일 동기화, 코드 실행 레인이 분리됐다.',
    tags: ['mesh-vote', 'fleet-director', 'araseo'],
  },
  {
    period: '2026.05.14 - 05.17',
    stage: '06',
    title: 'Claude Code 단일 스택과 공개 표면',
    summary:
      '외부 에이전트 환경을 정리하고 Claude Code 중심으로 통일했다. kangdaejong.com, work, 메일 라우팅, 큐 대시보드가 공개 표면으로 올라왔다.',
    tags: ['5-node peer', 'domain live', 'public surface'],
  },
  {
    period: '2026.05.25 - 05.28',
    stage: '07',
    title: 'Codex 백엔드 라이브',
    summary:
      'Codex REPL을 표준 실행 레인으로 세팅하고, 설계 투표와 분산 실행을 위한 Codex mesh 경로를 열었다.',
    tags: ['codex-mesh-vote', 'codex-loop-fleet', 'YOLO mode'],
  },
  {
    period: '2026.06.05 - 06.15',
    stage: '08',
    title: '역할 반전과 자기방어 인프라',
    summary:
      '본진은 거버넌스 게이트로 물러나고 자동 실행은 워커가 맡았다. 대신 증거 게이트, 원장, 가드 마커, 컨텍스트 하드클리어 같은 재발방지 장치가 들어갔다.',
    tags: ['action-ledger', 'sot-mark', 'evidence gate'],
  },
];

const nodes = [
  { name: 'Mac 본진', role: '정책, 머지, 최종 승인', lane: 'governance' },
  { name: '라이덴 WSL', role: '코드 수정, 분석, 로컬 검증', lane: 'execution' },
  { name: 'Mac mini', role: '자동 사이클, 빌드, 오케스트레이션', lane: 'orchestration' },
  { name: 'Desktop 3060Ti', role: 'GPU 실험, 장기 실행, 보조 워커', lane: 'compute' },
];

const flow = [
  { label: '입력', text: '텔레그램 한 줄 또는 tasks.md 디렉티브' },
  { label: '판단', text: '본진이 범위, 위험도, 라우팅을 확정' },
  { label: '실행', text: '워커가 worktree, branch, test, PR까지 수행' },
  { label: '검증', text: 'build, test, diff-check, evidence contract' },
  { label: '회수', text: 'mac-report, sot-mark, 수동 머지 게이트' },
];

const safeguards = [
  '큰 작업 전 증거 기반 preflight',
  '가드 마커와 정책 파일 보호',
  '외부발신, 배포, 머지 R3 게이트',
  '작업 상태는 tasks.md와 sot-mark 경유',
  '컨텍스트 과밀 시 하드클리어와 재개 기준',
  'stale 스킬을 감지하는 adapter scan',
];
---

<Layout
  title="에이전트 바이브코딩 변천사 - 강대종"
  description="강대종이 Claude/Codex 커스텀 스킬과 다중 노드 워커로 바이브코딩 시스템을 만들어온 변천사."
>
  <Fragment slot="head">
    <meta property="og:title" content="에이전트 바이브코딩 변천사 - 강대종" />
    <meta property="og:description" content="물리 4대, 논리 8노드, 스킬 39개로 확장된 바이브코딩 시스템 기록." />
    <meta property="og:image" content="https://work.kangdaejong.com/og-default.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://work.kangdaejong.com/vibecoding.html" />
    <meta property="og:site_name" content="강대종 작업장" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="에이전트 바이브코딩 변천사 - 강대종" />
    <meta name="twitter:description" content="물리 4대, 논리 8노드, 스킬 39개로 확장된 바이브코딩 시스템 기록." />
    <meta name="twitter:image" content="https://work.kangdaejong.com/og-default.png" />
    <link rel="canonical" href="https://work.kangdaejong.com/vibecoding.html" />
  </Fragment>

  <article class="vibe-page">
    <section class="vibe-hero" aria-labelledby="page-title">
      <div class="hero-copy">
        <p class="eyebrow">AGENTIC VIBECODING REPORT</p>
        <h1 id="page-title">에이전트 바이브코딩 변천사</h1>
        <p class="lead">
          반복 작업을 줄이려고 만든 작은 슬래시 커맨드가 물리 4대, 논리 8노드,
          스킬 39개를 가진 작업 시스템으로 커졌다. 이 페이지는 기능 목록이 아니라
          어디서 복잡해졌고, 어디서 다시 줄였는지 보는 변화 기록이다.
        </p>
      </div>
      <dl class="hero-stats" aria-label="바이브코딩 시스템 요약">
        {stats.map((stat) => (
          <div>
            <dt>{stat.label}</dt>
            <dd>{stat.value}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="system-map" aria-labelledby="map-title">
      <div class="section-head">
        <p class="section-number">00</p>
        <div>
          <p class="eyebrow">CURRENT SHAPE</p>
          <h2 id="map-title">지금은 한 명이 아니라 작은 운영체제처럼 일한다</h2>
        </div>
      </div>
      <div class="map-board" aria-label="입력부터 회수까지의 운영 흐름">
        {flow.map((item) => (
          <div class="map-step">
            <span>{item.label}</span>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="vibe-section" aria-labelledby="timeline-title">
      <div class="section-head">
        <p class="section-number">01</p>
        <div>
          <p class="eyebrow">TIMELINE</p>
          <h2 id="timeline-title">변화는 자동화보다 운영 기준을 만드는 쪽으로 갔다</h2>
        </div>
      </div>
      <ol class="timeline-list">
        {timeline.map((item) => (
          <li>
            <time>{item.period}</time>
            <div>
              <span class="stage">STEP {item.stage}</span>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <ul class="tag-list" aria-label={`${item.title} 관련 키워드`}>
                {item.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="vibe-section" aria-labelledby="node-title">
      <div class="section-head">
        <p class="section-number">02</p>
        <div>
          <p class="eyebrow">NODE MAP</p>
          <h2 id="node-title">노드는 늘었지만 역할은 더 좁게 나눴다</h2>
        </div>
      </div>
      <div class="node-table" role="table" aria-label="물리 노드 역할">
        {nodes.map((node) => (
          <div class="node-row" role="row">
            <div role="cell">
              <span>{node.lane}</span>
              <strong>{node.name}</strong>
            </div>
            <p role="cell">{node.role}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="vibe-section two-column" aria-labelledby="workflow-title">
      <div class="section-head">
        <p class="section-number">03</p>
        <div>
          <p class="eyebrow">OPERATING RULE</p>
          <h2 id="workflow-title">좋은 자동화는 더 많이 누르는 버튼이 아니라 덜 헷갈리는 절차다</h2>
        </div>
      </div>
      <div class="column-grid">
        <div class="plain-panel">
          <h3>처음의 문제</h3>
          <p>
            스킬이 늘어날수록 기억해야 할 규칙도 같이 늘었다. 어디까지 자동으로 해도 되는지,
            어떤 결과를 믿어도 되는지, 어떤 작업은 본진 승인이 필요한지 매번 흔들렸다.
          </p>
        </div>
        <div class="plain-panel">
          <h3>지금의 기준</h3>
          <p>
            워커는 손이다. 브랜치, 검증, PR, 보고까지 수행하지만 머지와 배포는 게이트를 통과한다.
            자동화가 빠르게 움직이되 되돌릴 수 있는 단위에서 멈추게 만든다.
          </p>
        </div>
      </div>
    </section>

    <section class="vibe-section" aria-labelledby="guard-title">
      <div class="section-head">
        <p class="section-number">04</p>
        <div>
          <p class="eyebrow">FORCING FUNCTIONS</p>
          <h2 id="guard-title">메모가 아니라 강제 장치가 재발을 줄인다</h2>
        </div>
      </div>
      <ul class="guard-list">
        {safeguards.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <footer class="vibe-footer">
      <p>마지막 갱신 2026.07.07</p>
      <a href="/lab/">lab으로 돌아가기</a>
    </footer>
  </article>

  <style>
    .vibe-page {
      display: flex;
      flex-direction: column;
      gap: 68px;
    }

    .vibe-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      gap: 42px;
      align-items: end;
      border-bottom: 1px solid var(--border);
      padding: 18px 0 42px;
    }

    .eyebrow {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0;
      margin-bottom: 12px;
    }

    h1 {
      color: var(--fg);
      font-size: 76px;
      line-height: 0.98;
      margin: 0 0 22px;
      max-width: 880px;
    }

    .lead {
      color: var(--fg-dim);
      font-size: 18px;
      line-height: 1.75;
      max-width: 760px;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: 1fr;
      border-top: 1px solid var(--fg);
    }

    .hero-stats div {
      display: grid;
      grid-template-columns: 92px minmax(0, 1fr);
      gap: 14px;
      align-items: baseline;
      border-bottom: 1px solid var(--border);
      min-height: 58px;
      padding: 14px 0;
    }

    .hero-stats dt {
      color: var(--fg-mute);
      font-size: 13px;
      font-weight: 600;
    }

    .hero-stats dd {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 16px;
      font-weight: 600;
      line-height: 1.45;
      min-width: 0;
    }

    .section-head {
      display: grid;
      grid-template-columns: 76px minmax(0, 1fr);
      gap: 24px;
      align-items: start;
      border-top: 1px solid var(--fg);
      padding-top: 22px;
      margin-bottom: 24px;
    }

    .section-number {
      color: var(--fg);
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 600;
    }

    h2 {
      color: var(--fg);
      font-size: 34px;
      line-height: 1.2;
      max-width: 760px;
    }

    .system-map {
      margin-top: -18px;
    }

    .map-board {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
      background: var(--bg);
    }

    .map-step {
      min-height: 156px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 18px;
    }

    .map-step span {
      display: block;
      color: var(--fg);
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 38px;
    }

    .map-step p {
      color: var(--fg-dim);
      font-size: 14px;
      line-height: 1.65;
    }

    .timeline-list {
      list-style: none;
      border-top: 1px solid var(--border);
    }

    .timeline-list > li {
      display: grid;
      grid-template-columns: 190px minmax(0, 1fr);
      gap: 32px;
      border-bottom: 1px solid var(--border);
      padding: 26px 0;
    }

    .timeline-list time {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.6;
    }

    .stage {
      color: var(--fg-mute);
      display: block;
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .timeline-list h3 {
      color: var(--fg);
      font-size: 22px;
      line-height: 1.3;
      margin-bottom: 10px;
    }

    .timeline-list p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.75;
      max-width: 760px;
    }

    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      list-style: none;
      margin-top: 14px;
    }

    .tag-list li {
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--fg-dim);
      font-family: var(--mono);
      font-size: 11px;
      line-height: 1;
      padding: 6px 9px;
    }

    .node-table {
      border-top: 1px solid var(--border);
    }

    .node-row {
      display: grid;
      grid-template-columns: minmax(220px, 0.45fr) minmax(0, 1fr);
      gap: 28px;
      border-bottom: 1px solid var(--border);
      padding: 22px 0;
    }

    .node-row span {
      color: var(--fg-mute);
      display: block;
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .node-row strong {
      color: var(--fg);
      display: block;
      font-size: 20px;
      line-height: 1.3;
    }

    .node-row p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.7;
      max-width: 640px;
    }

    .column-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .plain-panel {
      border: 1px solid var(--border);
      border-radius: 8px;
      min-height: 230px;
      padding: 22px;
    }

    .plain-panel h3 {
      color: var(--fg);
      font-size: 20px;
      line-height: 1.3;
      margin-bottom: 34px;
    }

    .plain-panel p {
      color: var(--fg-dim);
      font-size: 15px;
      line-height: 1.75;
    }

    .guard-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      list-style: none;
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
    }

    .guard-list li {
      color: var(--fg);
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      font-size: 15px;
      font-weight: 600;
      line-height: 1.55;
      min-height: 118px;
      padding: 18px;
    }

    .vibe-footer {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      border-top: 1px solid var(--border);
      padding-top: 20px;
    }

    .vibe-footer p,
    .vibe-footer a {
      color: var(--fg-mute);
      font-family: var(--mono);
      font-size: 12px;
    }

    @media (max-width: 900px) {
      .vibe-hero {
        grid-template-columns: 1fr;
        gap: 30px;
      }

      h1 {
        font-size: 56px;
      }

      .map-board,
      .guard-list {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .column-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .vibe-page {
        gap: 52px;
      }

      .vibe-hero {
        padding-top: 6px;
      }

      h1 {
        font-size: 42px;
        line-height: 1.04;
      }

      .lead {
        font-size: 16px;
      }

      .section-head {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      h2 {
        font-size: 27px;
      }

      .map-board,
      .guard-list {
        grid-template-columns: 1fr;
      }

      .map-step {
        min-height: auto;
      }

      .map-step span {
        margin-bottom: 14px;
      }

      .timeline-list > li,
      .node-row {
        grid-template-columns: 1fr;
        gap: 12px;
      }

      .plain-panel {
        min-height: auto;
      }

      .plain-panel h3 {
        margin-bottom: 18px;
      }

      .vibe-footer {
        flex-direction: column;
      }
    }
  </style>
</Layout>

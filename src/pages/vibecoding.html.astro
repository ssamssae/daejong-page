---
import Layout from '../layouts/Layout.astro';
import '../styles/lab.css';
---
<Layout title="에이전트 바이브코딩 변천사 - 강대종" description="강대종이 Claude/Codex 커스텀 스킬로 바이브코딩 시스템을 만들어온 변천사 보고서. 텔레그램 한 줄로 빌드·배포·할일관리·뉴스레터 발행을 처리하는 스킬 39개, 물리 5대/논리 10노드 mesh, 그리고 stale을 막는 자기방어 인프라(forcing function)의 진화를 기록합니다.">
  <Fragment slot="head">
    <!-- OG / Twitter Card (2026-05-25) -->
  <meta property="og:title" content="에이전트 바이브코딩 변천사 - 강대종">
  <meta property="og:description" content="강대종이 Claude/Codex 커스텀 스킬로 바이브코딩 시스템을 만들어온 변천사 보고서.">
  <meta property="og:image" content="https://work.kangdaejong.com/og-default.png">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://work.kangdaejong.com/vibecoding.html">
  <meta property="og:site_name" content="강대종 - 1인 개발 포트폴리오">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="에이전트 바이브코딩 변천사 - 강대종">
  <meta name="twitter:description" content="강대종이 Claude/Codex 커스텀 스킬로 바이브코딩 시스템을 만들어온 변천사 보고서.">
  <meta name="twitter:image" content="https://work.kangdaejong.com/og-default.png">
  <link rel="canonical" href="https://work.kangdaejong.com/vibecoding.html">
  <script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://work.kangdaejong.com/#person",
      "name": "강대종",
      "jobTitle": "Solo founder / Vibe coder",
      "url": "https://work.kangdaejong.com/",
      "sameAs": ["https://github.com/ssamssae"],
      "description": "1인 개발자 / Vibe coder / Solo founder"
    },
    {
      "@type": "WebSite",
      "@id": "https://work.kangdaejong.com/#website",
      "name": "강대종",
      "url": "https://work.kangdaejong.com/",
      "inLanguage": "ko",
      "author": {"@id": "https://work.kangdaejong.com/#person"}
    }
  ]
}
</script>
  <style is:global>
    /* 페이지 고유 레이아웃 (색은 전부 page-dark 토큰 / --page-accent 참조) */
    .vc-report { margin-top: 8px; }

    /* 섹션 헤더 */
    h2.section-title {
      font-size: 20px;
      font-weight: 700;
      color: var(--fg);
      margin: 48px 0 24px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--border);
    }
    h2.section-title span { color: var(--page-accent); }

    /* report 인트로 카드 */
    .vc-hero-card {
      background: var(--bg-elev);
      border: 1px solid var(--border);
      border-left: 3px solid var(--page-accent);
      border-radius: 12px;
      padding: 28px 26px;
      margin-bottom: 16px;
    }
    .vc-hero-label {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      color: var(--page-accent);
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .vc-hero-card h2 {
      font-size: 24px;
      font-weight: 700;
      color: var(--fg);
      margin-bottom: 14px;
      line-height: 1.35;
      word-break: keep-all;
    }
    .vc-hero-card p {
      font-size: 15px;
      color: var(--fg-dim);
      line-height: 1.7;
      max-width: 600px;
    }
    .hero-stats {
      display: flex;
      gap: 24px;
      margin-top: 24px;
      flex-wrap: wrap;
    }
    .stat { text-align: center; }
    .stat-num {
      font-family: var(--mono);
      font-size: 30px;
      font-weight: 600;
      color: var(--page-accent);
      line-height: 1;
    }
    .stat-label {
      font-size: 12px;
      color: var(--fg-mute);
      margin-top: 6px;
    }

    /* Timeline */
    .timeline { position: relative; margin-bottom: 16px; }
    .timeline::before {
      content: '';
      position: absolute;
      left: 20px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: var(--border);
    }
    .tl-item {
      position: relative;
      padding-left: 56px;
      margin-bottom: 32px;
    }
    .tl-dot {
      position: absolute;
      left: 12px;
      top: 4px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--page-accent);
      border: 3px solid var(--bg);
      box-shadow: 0 0 0 2px var(--page-accent);
    }
    .tl-dot.epoch1 { background: var(--fg-mute); box-shadow: 0 0 0 2px var(--fg-mute); }
    .tl-dot.epoch2 { background: var(--accent); box-shadow: 0 0 0 2px var(--accent); }
    .tl-dot.epoch3 { background: var(--success); box-shadow: 0 0 0 2px var(--success); }
    .tl-dot.epoch4 { background: var(--warn); box-shadow: 0 0 0 2px var(--warn); }
    .tl-dot.epoch5 { background: var(--accent-2); box-shadow: 0 0 0 2px var(--accent-2); }
    .tl-dot.epoch6 { background: var(--accent-dim); box-shadow: 0 0 0 2px var(--accent-dim); }

    .tl-date {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 600;
      color: var(--fg-mute);
      margin-bottom: 6px;
      letter-spacing: 0.5px;
    }
    .tl-card {
      background: var(--bg-elev);
      border-radius: 10px;
      padding: 20px 22px;
      border: 1px solid var(--border);
      transition: border-color 0.15s;
    }
    .tl-card:hover { border-color: var(--page-accent); }
    .tl-epoch {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 8px;
      margin-bottom: 10px;
    }
    .epoch1 .tl-epoch { background: var(--bg-elev2); color: var(--fg-dim); }
    .epoch2 .tl-epoch { background: var(--accent-bg); color: var(--accent); }
    .epoch3 .tl-epoch { background: rgba(52,211,153,0.12); color: var(--success); }
    .epoch4 .tl-epoch { background: rgba(251,146,60,0.12); color: var(--warn); }
    .epoch5 .tl-epoch { background: rgba(255,0,170,0.12); color: var(--accent-2); }
    .epoch6 .tl-epoch { background: rgba(0,184,212,0.12); color: var(--accent-dim); }

    .tl-title {
      font-size: 17px;
      font-weight: 700;
      color: var(--fg);
      margin-bottom: 8px;
      word-break: keep-all;
    }
    .tl-desc {
      font-size: 14px;
      color: var(--fg-dim);
      line-height: 1.7;
    }
    .tl-desc code {
      font-family: var(--mono);
      font-size: 12px;
      background: var(--bg-elev2);
      color: var(--fg);
      padding: 1px 6px;
      border-radius: 5px;
    }
    .tl-skills {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 12px;
    }
    .skill-badge {
      font-size: 11px;
      font-family: var(--mono);
      background: var(--bg-elev2);
      color: var(--fg-dim);
      padding: 2px 8px;
      border-radius: 6px;
      font-weight: 600;
      border: 1px solid var(--border);
    }
    .skill-badge.new { background: rgba(52,211,153,0.10); color: var(--success); border-color: rgba(52,211,153,0.25); }
    .skill-badge.del { background: rgba(255,90,106,0.10); color: var(--danger); border-color: rgba(255,90,106,0.25); text-decoration: line-through; }

    /* Architecture */
    .arch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 16px;
    }
    @media (max-width: 600px) { .arch-grid { grid-template-columns: 1fr; } }
    .arch-card {
      background: var(--bg-elev);
      border-radius: 10px;
      padding: 20px;
      border: 1px solid var(--border);
      text-align: center;
    }
    .arch-icon { font-size: 32px; margin-bottom: 10px; }
    .arch-name { font-size: 14px; font-weight: 700; color: var(--fg); margin-bottom: 6px; }
    .arch-role { font-size: 12px; color: var(--fg-mute); line-height: 1.6; }

    /* Skills count */
    .skills-summary {
      background: var(--bg-elev);
      border-radius: 10px;
      padding: 24px;
      border: 1px solid var(--border);
      margin-bottom: 16px;
    }
    .skills-summary p { font-size: 14px; color: var(--fg-dim); margin-bottom: 16px; line-height: 1.7; }
    .skills-summary code {
      font-family: var(--mono);
      font-size: 12px;
      background: var(--bg-elev2);
      color: var(--fg);
      padding: 1px 6px;
      border-radius: 5px;
    }
    .skills-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    /* Workflow */
    .workflow-wrap { margin-bottom: 16px; display: flex; flex-direction: column; gap: 20px; }
    .wf-block { background: var(--bg-elev); border-radius: 10px; padding: 24px; border: 1px solid var(--border); }
    .wf-subtitle { font-size: 12px; font-weight: 700; color: var(--fg-mute); margin-bottom: 18px; letter-spacing: 0.8px; text-transform: uppercase; }
    .routing-grid { display: grid; grid-template-columns: 1fr auto 1fr; gap: 16px; align-items: start; }
    .routing-col { display: flex; flex-direction: column; gap: 8px; }
    .routing-label { font-size: 11px; font-weight: 700; color: var(--fg-mute); margin-bottom: 2px; letter-spacing: 0.5px; text-transform: uppercase; }
    .routing-node { border-radius: 10px; padding: 10px 14px; font-size: 13px; font-weight: 600; line-height: 1.5; border: 1px solid var(--border); }
    .routing-node small { display: block; font-size: 11px; font-weight: 400; color: var(--fg-mute); margin-top: 2px; }
    .routing-node.trigger { background: var(--accent-bg); color: var(--accent); }
    .routing-node.mac { background: rgba(251,146,60,0.10); color: var(--warn); }
    .routing-node.wsl { background: rgba(0,229,255,0.07); color: var(--accent); }
    .routing-node.mini { background: rgba(52,211,153,0.08); color: var(--success); }
    .routing-node.result { background: rgba(255,0,170,0.08); color: var(--accent-2); }
    .routing-mid { display: flex; align-items: center; justify-content: center; font-size: 22px; color: var(--fg-mute); padding-top: 28px; }
    .wf-pipeline { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .wf-step { border-radius: 10px; padding: 12px 14px; text-align: center; font-size: 13px; font-weight: 700; min-width: 88px; flex: 1; border: 1px solid var(--border); }
    .wf-step small { display: block; font-size: 11px; font-weight: 400; color: var(--fg-mute); margin-top: 3px; line-height: 1.4; }
    .wf-step.plan { background: var(--accent-bg); color: var(--accent); }
    .wf-step.execute { background: rgba(52,211,153,0.10); color: var(--success); }
    .wf-step.judge { background: rgba(251,146,60,0.10); color: var(--warn); }
    .wf-step.report { background: rgba(255,0,170,0.10); color: var(--accent-2); }
    .wf-arr { font-size: 16px; color: var(--fg-mute); flex-shrink: 0; }
    .wf-note { margin-top: 12px; font-size: 12px; color: var(--fg-mute); line-height: 1.6; }
    @media (max-width: 600px) {
      .routing-grid { grid-template-columns: 1fr; }
      .routing-mid { padding-top: 0; transform: rotate(90deg); width: fit-content; }
      .wf-pipeline { gap: 4px; }
      .wf-step { min-width: 64px; padding: 10px 8px; font-size: 12px; }
    }

    /* Proposal / 콘텐츠 카드 */
    .proposal {
      background: var(--bg-elev);
      border-radius: 12px;
      padding: 28px;
      border: 1px solid var(--border);
      border-left: 3px solid var(--page-accent);
      margin-bottom: 16px;
    }
    .proposal h3 {
      font-size: 18px;
      font-weight: 700;
      color: var(--page-accent);
      margin-bottom: 20px;
    }
    .proposal > p { color: var(--fg-dim); }
    .proposal strong { color: var(--fg); }
    .proposal-item {
      display: flex;
      gap: 14px;
      margin-bottom: 20px;
      align-items: flex-start;
    }
    .proposal-num {
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--page-accent);
      color: var(--bg);
      font-size: 13px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .proposal-text h4 { font-size: 15px; font-weight: 700; color: var(--fg); margin-bottom: 4px; }
    .proposal-text p { font-size: 13px; color: var(--fg-dim); line-height: 1.7; }

    /* 에이전틱 엔지니어링 비교 박스 */
    .ae-compare { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 20px; }
    @media (max-width: 600px) { .ae-compare { grid-template-columns: 1fr; } }
    .ae-col { background: var(--bg-elev2); border-radius: 10px; padding: 20px; border: 1px solid var(--border); }
    .ae-col-vibe { border-left: 3px solid var(--warn); }
    .ae-col-agentic { border-left: 3px solid var(--success); }
    .ae-col-head { font-weight: 700; margin-bottom: 8px; }
    .ae-col-vibe .ae-col-head { color: var(--warn); }
    .ae-col-agentic .ae-col-head { color: var(--success); }
    .ae-col ul { color: var(--fg-dim); font-size: 14px; line-height: 1.8; padding-left: 16px; margin: 0; }

    /* 이미 시작했다 — 흐름 스텝 */
    .flow-steps { margin-top: 16px; display: flex; flex-direction: column; gap: 10px; }
    .flow-step {
      background: var(--bg-elev2);
      border-radius: 10px;
      padding: 14px 18px;
      border-left: 3px solid var(--accent);
      font-size: 14px;
      color: var(--fg-dim);
      line-height: 1.7;
    }
    .flow-step.alt { border-left-color: var(--accent-2); }
    .flow-step strong { color: var(--fg); }

    /* 어디서부터 — 축 카드 */
    .axis-list { margin-top: 16px; display: flex; flex-direction: column; gap: 12px; }
    .axis-card { background: var(--bg-elev2); border-radius: 10px; padding: 16px 18px; border: 1px solid var(--border); }
    .axis-card-head { font-weight: 700; color: var(--page-accent); margin-bottom: 6px; }
    .axis-card p { font-size: 14px; color: var(--fg-dim); line-height: 1.7; }

    .vc-foot-links {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-mute);
      text-align: center;
      margin-top: 8px;
    }
    .vc-foot-links a { color: var(--accent); text-decoration: none; }
    .vc-foot-links a:hover { color: var(--accent-2); }
  </style>
  </Fragment>

  <div class="lab-page" style="--page-accent: var(--accent)">
    <section class="lab-hero">
      <h1 class="logo">에이전트 바이브코딩 변천사</h1>
      <p class="tagline">agentic vibe coding · 물리 5대 / 논리 10노드 mesh report</p>
      <p class="intro">Claude/Codex 커스텀 스킬(/skill)을 메인으로 반복 작업을 자동화하는 시스템. 텔레그램 한 줄로 빌드·배포·할일관리·뉴스레터 발행을 처리하는 바이브코딩 인프라가 어떻게 만들어졌고, stale을 막는 자기방어 레이어까지 어떻게 진화했는지 기록합니다.</p>
    </section>

    <div class="vc-report">

    <div class="vc-hero-card">
      <div class="vc-hero-label">Report · 2026-06-21 갱신</div>
      <h2>혼자 만들고 혼자 다듬어온<br>에이전트 스킬 시스템</h2>
      <p>Claude/Codex 커스텀 스킬(/skill)을 기반으로, 텔레그램 한 줄로 빌드·배포·할일관리·뉴스레터 발행을 처리하는 바이브코딩 인프라. 어떻게 만들어졌고, 어떻게 "스스로를 의심하는" 자기방어 인프라까지 진화했는지 기록합니다. 현재 모델/엔진 역할은 Codex 실행 레인 + Claude 리뷰/게이트 레인으로 분리합니다.</p>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-num">39</div>
          <div class="stat-label">활성 스킬</div>
        </div>
        <div class="stat">
          <div class="stat-num">5</div>
          <div class="stat-label">물리 기기</div>
        </div>
        <div class="stat">
          <div class="stat-num">10</div>
          <div class="stat-label">논리 노드 (Codex 5 + Claude 5)</div>
        </div>
        <div class="stat">
          <div class="stat-num">~7주</div>
          <div class="stat-label">제작 기간</div>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <h2 class="section-title"><span>01</span> 변천사 타임라인</h2>
    <div class="timeline">

      <div class="tl-item epoch1">
        <div class="tl-dot epoch1"></div>
        <div class="tl-date">2026-04-27 이전</div>
        <div class="tl-card">
          <span class="tl-epoch">1기 · 태동</span>
          <div class="tl-title">첫 슬래시 커맨드 탄생</div>
          <div class="tl-desc">
            반복되는 수작업을 줄이고 싶다는 욕구에서 출발. todo · worklog · done · goodnight 같은 일상 관리 스킬이 가장 먼저 만들어졌다. 이 시기는 단일 Mac 세션에서 모든 것을 처리하는 단순한 형태.
            <br><br>아직 기기 간 협력 개념은 없었고, 스킬은 "자동으로 파일에 기록해줘" 수준.
          </div>
          <div class="tl-skills">
            <span class="skill-badge new">/todo</span>
            <span class="skill-badge new">/worklog</span>
            <span class="skill-badge new">/done</span>
            <span class="skill-badge new">/goodnight</span>
            <span class="skill-badge new">/insta-post</span>
            <span class="skill-badge del">/morning-briefing</span>
            <span class="skill-badge del">/evening-wrap</span>
            <span class="skill-badge del">/trend</span>
          </div>
        </div>
      </div>

      <div class="tl-item epoch2">
        <div class="tl-dot epoch2"></div>
        <div class="tl-date">2026-04-29 ~ 05-04</div>
        <div class="tl-card">
          <span class="tl-epoch">2기 · 멀티기기 확장</span>
          <div class="tl-title">Mac + WSL 2-way 핸드오프 자동화</div>
          <div class="tl-desc">
            WSL(Windows 개발 환경)을 두 번째 작업자로 편입. 본진 → WSL 자동 paste 운반체 + WSL → 본진 결과 자동 회신 채널을 만들어 기기 간 작업을 zero-touch로 주고받기 시작. 브랜치 분리 원칙(mac/* · wsl/*)도 이때 확립.
            <br><br>parallel-cycle 등장이 이 시기 핵심. 동시에 N개 작업을 각 기기에 배분하는 최초의 병렬 실행 패턴.
          </div>
          <div class="tl-skills">
            <span class="skill-badge new">/parallel-cycle</span>
            <span class="skill-badge new">/session-clear</span>
            <span class="skill-badge new">/pull-apps</span>
            <span class="skill-badge new">/wsl-flutter-test</span>
            <span class="skill-badge new">/submit-app</span>
            <span class="skill-badge del">/handoff</span>
            <span class="skill-badge del">/sync</span>
            <span class="skill-badge del">/land</span>
          </div>
        </div>
      </div>

      <div class="tl-item epoch3">
        <div class="tl-dot epoch3"></div>
        <div class="tl-date">2026-05-05 ~ 05-07</div>
        <div class="tl-card">
